{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "root": true,
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "css": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnresolvedImports": "off",
        "useImportExtensions": "off"
      },
      "style": {
        "useImportType": "warn",
        "noNonNullAssertion": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noExportsInTest": "off",
        "noControlCharactersInRegex": "warn",
        "useIterableCallbackReturn": "warn",
        "noDoubleEquals": "warn"
      },
      "a11y": {
        "useButtonType": "warn"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/out-tsc",
      "!**/node_modules",
      "!**/.nx",
      "!**/.venv",
      "!**/pnpm-lock.yaml",
      "!docs/**/*.md",
      "!docs/**/*.mdx",
      "!**/*.template",
      "!**/*.grit",
      "!**/files"
    ]
  }
}
