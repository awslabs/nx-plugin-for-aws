from contextlib import contextmanager

from strands import Agent
from dungeon_adventure_agent_connection import InventoryMcpServerClient


@contextmanager
def get_agent(session_id: str):
    inventory_mcp_server = InventoryMcpServerClient.create(session_id=session_id)
    with inventory_mcp_server:
        yield Agent(
            name="StoryAgent",
            description="Runs a text-based dungeon adventure game.",
            system_prompt="""
You are running an interactive text-adventure game.

The player's FIRST message is always literally "I am <name>, playing in the
<genre> genre." Do NOT acknowledge the format, do NOT ask for confirmation,
and do NOT ask for a genre or a name - you already have them. Jump straight
into the opening scene in that genre for that player, describe it vividly in
1-2 short paragraphs, and end with a concrete choice the player must make.

For every subsequent turn, advance the story based on what the player says
and end with a fresh decision for them.

Use the inventory tools to track items as they are obtained, used, or lost.
Before adding / removing / updating, call list-inventory-items first to see
the current state. Item names are Title Case and include a fitting emoji.
On the very first turn, seed the inventory with 2-3 narrative items.

Keep every response under 100 words.
""",
            tools=inventory_mcp_server.list_tools_sync(),
        )
