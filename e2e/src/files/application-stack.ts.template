import * as cdk from 'aws-cdk-lib';
import { Construct } from 'constructs';
import {
  UserIdentity,
  Website,
  MyApi,
  MyApiHttp,
  MyApiCustom,
  MyApiCustomHttp,
  PyApi,
  PyApiHttp,
  PyApiCustom,
  PyApiCustomHttp,
  PyProjectMyFunction,
  MyMcpServer,
  MyAgent,
  MyPyA2aAgent,
  MyPyLangchainAgent,
  MyPyLangchainHttpAgent,
  MyPyLangchainA2aAgent,
  MyPyAguiAgent,
  TsProjectMyFunction,
  TsProjectAgent,
  MyTsA2aAgent,
  MyTsAguiAgent,
  HostedMcpServer,
  MySmithyApi,
  MyTable,
  MyGateway,
  ParentGateway,
} from ':e2e-test/common-constructs';

export class ApplicationStack extends cdk.Stack {
  constructor(scope: Construct, id: string, props?: cdk.StackProps) {
    super(scope, id, props);

    const identity = new UserIdentity(this, 'UserIdentity');
    const myapi = new MyApi(this, 'MyApi', {
      integrations: MyApi.defaultIntegrations(this).build(),
    });
    myapi.grantInvokeAccess(identity.identityPool.authenticatedRole);
    const pyapi = new PyApi(this, 'PyApi', {
      integrations: PyApi.defaultIntegrations(this).build(),
    });
    pyapi.grantInvokeAccess(identity.identityPool.authenticatedRole);
    new Website(this, 'Website');
    const pyFn = new PyProjectMyFunction(this, 'MyFunction');
    new cdk.CfnOutput(this, 'PyFunctionArn', {
      value: pyFn.functionArn,
    });
    new MyApiHttp(this, 'MyApiHttp', {
      integrations: MyApiHttp.defaultIntegrations(this).build(),
    });
    new PyApiHttp(this, 'PyApiHttp', {
      integrations: PyApiHttp.defaultIntegrations(this).build(),
    });
    const smithyapi = new MySmithyApi(this, 'MySmithyApi', {
      integrations: MySmithyApi.defaultIntegrations(this).build(),
    });
    smithyapi.grantInvokeAccess(identity.identityPool.authenticatedRole);
    new MyApiCustom(this, 'MyApiCustom', {
      integrations: MyApiCustom.defaultIntegrations(this).build(),
    });
    new MyApiCustomHttp(this, 'MyApiCustomHttp', {
      integrations: MyApiCustomHttp.defaultIntegrations(this).build(),
    });
    new PyApiCustom(this, 'PyApiCustom', {
      integrations: PyApiCustom.defaultIntegrations(this).build(),
    });
    new PyApiCustomHttp(this, 'PyApiCustomHttp', {
      integrations: PyApiCustomHttp.defaultIntegrations(this).build(),
    });
    const tsFn = new TsProjectMyFunction(this, 'TsProjectMyFunction');
    new cdk.CfnOutput(this, 'TsFunctionArn', {
      value: tsFn.functionArn,
    });

    const pyAgent = new MyAgent(this, 'MyAgent');
    new cdk.CfnOutput(this, 'PyAgentArn', {
      value: pyAgent.agentCoreRuntime.agentRuntimeArn,
    });
    const tsAgent = new TsProjectAgent(this, 'TsProjectAgent');
    new cdk.CfnOutput(this, 'TsAgentArn', {
      value: tsAgent.agentCoreRuntime.agentRuntimeArn,
    });
    const tsA2aAgent = new MyTsA2aAgent(this, 'MyTsA2aAgent');
    new cdk.CfnOutput(this, 'TsA2aAgentArn', {
      value: tsA2aAgent.agentCoreRuntime.agentRuntimeArn,
    });
    const pyA2aAgent = new MyPyA2aAgent(this, 'MyPyA2aAgent');
    new cdk.CfnOutput(this, 'PyA2aAgentArn', {
      value: pyA2aAgent.agentCoreRuntime.agentRuntimeArn,
    });
    const pyLangchainAgent = new MyPyLangchainAgent(this, 'MyPyLangchainAgent');
    new cdk.CfnOutput(this, 'PyLangchainAgentArn', {
      value: pyLangchainAgent.agentCoreRuntime.agentRuntimeArn,
    });
    const pyLangchainHttpAgent = new MyPyLangchainHttpAgent(
      this,
      'MyPyLangchainHttpAgent',
    );
    new cdk.CfnOutput(this, 'PyLangchainHttpAgentArn', {
      value: pyLangchainHttpAgent.agentCoreRuntime.agentRuntimeArn,
    });
    const pyLangchainA2aAgent = new MyPyLangchainA2aAgent(
      this,
      'MyPyLangchainA2aAgent',
    );
    new cdk.CfnOutput(this, 'PyLangchainA2aAgentArn', {
      value: pyLangchainA2aAgent.agentCoreRuntime.agentRuntimeArn,
    });

    // AG-UI agents — connected to the website so the browser-driven website
    // integration test can exercise the AG-UI protocol end-to-end.
    const tsAguiAgent = new MyTsAguiAgent(this, 'MyTsAguiAgent');
    const pyAguiAgent = new MyPyAguiAgent(this, 'MyPyAguiAgent');

    const pyMcp = new MyMcpServer(this, 'MyMcpServer');
    new cdk.CfnOutput(this, 'PyMcpServerArn', {
      value: pyMcp.agentCoreRuntime.agentRuntimeArn,
    });
    const tsMcp = new HostedMcpServer(this, 'HostedMcpServer');
    new cdk.CfnOutput(this, 'TsMcpServerArn', {
      value: tsMcp.agentCoreRuntime.agentRuntimeArn,
    });

    // Grant the agents permissions to invoke the connected MCP servers
    tsMcp.grantInvokeAccess(tsAgent);
    pyMcp.grantInvokeAccess(tsAgent);
    pyMcp.grantInvokeAccess(pyAgent);
    // LangChain agent -> Python MCP server.
    pyMcp.grantInvokeAccess(pyLangchainAgent);
    // The TypeScript AG-UI agent is connected to the TypeScript MCP server and
    // calls it on startup, so it needs invoke access too.
    tsMcp.grantInvokeAccess(tsAguiAgent);

    // Grant the HTTP agents permission to invoke the A2A agents so
    // we can verify A2A invocation with SigV4 end-to-end.
    tsA2aAgent.grantInvokeAccess(tsAgent);
    pyA2aAgent.grantInvokeAccess(tsAgent);
    tsA2aAgent.grantInvokeAccess(pyAgent);
    pyA2aAgent.grantInvokeAccess(pyAgent);
    // LangChain agent -> Python A2A agent.
    pyA2aAgent.grantInvokeAccess(pyLangchainAgent);

    // Grant the website's authenticated users permission to invoke every agent
    // the website is connected to (HTTP + AG-UI, TypeScript + Python), so the
    // browser-driven website integration test can invoke them with SigV4.
    tsAgent.grantInvokeAccess(identity.identityPool.authenticatedRole);
    pyAgent.grantInvokeAccess(identity.identityPool.authenticatedRole);
    tsAguiAgent.grantInvokeAccess(identity.identityPool.authenticatedRole);
    pyAguiAgent.grantInvokeAccess(identity.identityPool.authenticatedRole);

    new MyTable(this, 'MyTable');

    // AgentCore Gateway fronting both MCP servers, exercising both
    // gateway-connection generators (ts/py agent -> gateway) and both
    // mcp-connection edges (gateway -> ts/py mcp-server).
    const myGateway = new MyGateway(this, 'MyGateway');
    myGateway.addMcpServer(tsMcp);
    myGateway.addMcpServer(pyMcp);
    myGateway.grantInvokeAccess(tsAgent);
    myGateway.grantInvokeAccess(pyAgent);
    myGateway.grantInvokeAccess(pyLangchainAgent);
    new cdk.CfnOutput(this, 'MyGatewayUrl', {
      value: myGateway.gateway.gatewayUrl ?? '',
    });

    // Chained gateways: the parent gateway fronts MyGateway, re-exposing its
    // tools under `my-gateway___<target>___<tool>` (gateway -> gateway edge).
    const parentGateway = new ParentGateway(this, 'ParentGateway');
    parentGateway.addGateway(myGateway);
    new cdk.CfnOutput(this, 'ParentGatewayUrl', {
      value: parentGateway.gateway.gatewayUrl ?? '',
    });
  }
}
