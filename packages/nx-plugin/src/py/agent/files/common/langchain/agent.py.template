import os

from langchain.agents import create_agent
from langchain_aws import ChatBedrockConverse
from langchain_core.tools import tool
from langgraph.checkpoint.memory import InMemorySaver

# Pass region_name explicitly so an ambient AWS_REGION does not silently shadow the
# region the agent should run in. The Bedrock provider otherwise defaults to us-east-1.
REGION = os.environ.get("AWS_REGION", "us-east-1")
# ChatBedrockConverse requires a model id (unlike Strands, which picks a Bedrock default).
# Override with the MODEL_ID env var to use a different model / inference profile.
MODEL_ID = os.environ.get("MODEL_ID", "anthropic.claude-3-5-haiku-20241022-v1:0")


@tool
def subtract(a: int, b: int) -> int:
    """Subtract b from a."""
    return a - b


def get_agent():
    # ChatBedrockConverse drives the Bedrock Converse API. region_name is passed
    # explicitly so an ambient AWS_REGION cannot shadow the intended region.
    model = ChatBedrockConverse(model_id=MODEL_ID, region_name=REGION)
    # ag_ui_langgraph.LangGraphAgent.run() calls graph.aget_state(), which REQUIRES a
    # checkpointer (the Strands AG-UI adapter needed none). InMemorySaver keeps per-thread
    # state within one process, keyed by the AgentCore session id (rebound per request in
    # main.py). For a multi-replica deployment, swap this for a durable saver
    # (DynamoDB / Redis) so session state survives a replica swap.
    return create_agent(
        model=model,
        tools=[subtract],
        system_prompt="""
You are a mathematical wizard.
Use your tools for mathematical tasks.
Refer to tools as your 'spellbook'.
""",
        checkpointer=InMemorySaver(),
    )
