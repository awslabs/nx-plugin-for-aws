import os

from langchain_core.tools import BaseTool

from <%- agentConnectionModuleName %>.core.agentcore_mcp_client_langchain import (
    AgentCoreMCPClientLangChain,
)
from <%- agentConnectionModuleName %>.core.runtime_config import (
    get_agentcore_runtime_config,
)


class <%- mcpServerClassName %>ClientLangChain:
    """Loads LangChain tools from the <%- mcpServerClassName %> MCP server."""

    @staticmethod
    def create() -> list[BaseTool]:
        if os.environ.get("SERVE_LOCAL") == "true":
            return AgentCoreMCPClientLangChain.without_auth(
                "http://localhost:<%- mcpServerPort %>/mcp"
            )
        config = get_agentcore_runtime_config()
        agent_runtime_arn = config.get("agentRuntimes", {}).get(
            "<%- mcpServerClassName %>"
        )
        if not agent_runtime_arn:
            raise RuntimeError(
                "No connected MCP server runtime named '<%- mcpServerClassName %>' found in runtime configuration."
            )
        return AgentCoreMCPClientLangChain.with_iam_auth(agent_runtime_arn)
