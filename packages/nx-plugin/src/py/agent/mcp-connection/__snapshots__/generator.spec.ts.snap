"from proj_agent_connection import InventoryMcpClientStrands
from contextlib import contextmanager

from strands import Agent, tool
from strands_tools import current_time


# Define a custom tool
@tool
def subtract(a: int, b: int) -> int:
    return a - b


@contextmanager
def get_agent(session_id: str):
    inventory_mcp = InventoryMcpClientStrands.create()
    with (
        inventory_mcp,
    ):
        yield Agent(
            system_prompt="""
You are a mathematical wizard.
Use your tools for mathematical tasks.
Refer to tools as your 'spellbook'.
""",
            tools=[subtract, current_time, *inventory_mcp.list_tools_sync()],
        )
"
`;
