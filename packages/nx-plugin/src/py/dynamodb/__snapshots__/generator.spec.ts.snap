"terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
  }
}

variable "billing_mode" {
  description = "Controls how you are charged for read and write throughput."
  type        = string
  default     = "PAY_PER_REQUEST"
}

variable "point_in_time_recovery_enabled" {
  description = "Whether to enable point-in-time recovery for the table."
  type        = bool
  default     = true
}

variable "deletion_protection_enabled" {
  description = "Whether to enable deletion protection on the table."
  type        = bool
  default     = true
}

variable "enable_key_rotation" {
  description = "Whether to enable automatic key rotation on the KMS key used to encrypt the table."
  type        = bool
  default     = true
}

locals {
  dynamodb_config = jsondecode(file("\${path.module}/../../../../../../../packages/my_table/config.json"))
  global_secondary_indexes = [for gsi in local.dynamodb_config.tableConfig.globalSecondaryIndexes : {
    name            = gsi.indexName
    hash_key        = gsi.partitionKey
    range_key       = try(gsi.sortKey, null)
    projection_type = "ALL"
  }]
}

module "dynamodb_table" {
  source                         = "../../../core/dynamodb"
  name                           = "proj-my-table"
  billing_mode                   = var.billing_mode
  point_in_time_recovery_enabled = var.point_in_time_recovery_enabled
  deletion_protection_enabled    = var.deletion_protection_enabled
  enable_key_rotation            = var.enable_key_rotation
  global_secondary_indexes       = local.global_secondary_indexes
}

module "add_to_runtime_config" {
  source = "../../../core/runtime-config/entry"

  namespace = "dynamodb"
  key       = local.dynamodb_config.runtimeConfigKey
  value = {
    tableName = module.dynamodb_table.table_name
  }
}
"
`;

exports[`py#dynamodb generator > should generate the dynamodb project > packages/common/py-dynamodb/scripts/create_local_table.py 1`] = `
"import json
import time
from typing import Any

import boto3
from botocore.exceptions import ClientError

with open("config.json") as f:
    config = json.load(f)
global_secondary_indexes = config.get("tableConfig", {}).get(
    "globalSecondaryIndexes", []
)
serve_local = config["serveLocal"]
table_name = serve_local["tableName"]
port = serve_local["port"]
region = serve_local["region"]
access_key_id = serve_local["accessKeyId"]
secret_access_key = serve_local["secretAccessKey"]
request_timeout = serve_local["requestTimeoutMs"] / 1000

client = boto3.client(
    "dynamodb",
    endpoint_url=f"http://localhost:{port}",
    region_name=region,
    aws_access_key_id=access_key_id,
    aws_secret_access_key=secret_access_key,
    config=boto3.session.Config(
        connect_timeout=request_timeout,
        read_timeout=request_timeout,
    ),
)


def wait_for_table_active(tbl_name: str) -> None:
    while True:
        response = client.describe_table(TableName=tbl_name)
        table = response["Table"]
        all_active = table.get("TableStatus") == "ACTIVE" and all(
            gsi.get("IndexStatus") == "ACTIVE"
            for gsi in table.get("GlobalSecondaryIndexes", [])
        )
        if all_active:
            return
        time.sleep(0.5)


seen_attr_names: set = set()
attribute_definitions = [
    {"AttributeName": "pk", "AttributeType": "S"},
    {"AttributeName": "sk", "AttributeType": "S"},
]
seen_attr_names.update(["pk", "sk"])

for gsi in global_secondary_indexes:
    for attr_name in [gsi["partitionKey"], gsi.get("sortKey")]:
        if attr_name and attr_name not in seen_attr_names:
            seen_attr_names.add(attr_name)
            attribute_definitions.append(
                {"AttributeName": attr_name, "AttributeType": "S"}
            )

gsi_specs = [
    {
        "IndexName": gsi["indexName"],
        "KeySchema": [
            {"AttributeName": gsi["partitionKey"], "KeyType": "HASH"},
            *(
                [{"AttributeName": gsi["sortKey"], "KeyType": "RANGE"}]
                if gsi.get("sortKey")
                else []
            ),
        ],
        "Projection": {"ProjectionType": "ALL"},
    }
    for gsi in global_secondary_indexes
]

for attempt in range(30):
    try:
        kwargs: dict[str, Any] = {
            "TableName": table_name,
            "AttributeDefinitions": attribute_definitions,
            "KeySchema": [
                {"AttributeName": "pk", "KeyType": "HASH"},
                {"AttributeName": "sk", "KeyType": "RANGE"},
            ],
            "BillingMode": "PAY_PER_REQUEST",
        }
        if gsi_specs:
            kwargs["GlobalSecondaryIndexes"] = gsi_specs
        client.create_table(**kwargs)
        print(f"Created table: {table_name}")
        for gsi in gsi_specs:
            print(f"Created GSI: {gsi['IndexName']}")
        break
    except ClientError as e:
        if e.response["Error"]["Code"] == "ResourceInUseException":
            # Table already exists — sync GSIs to match desired state.
            response = client.describe_table(TableName=table_name)
            existing_gsis = response["Table"].get("GlobalSecondaryIndexes", [])
            existing_names = {g["IndexName"] for g in existing_gsis}
            desired_names = {g["indexName"] for g in global_secondary_indexes}

            # DynamoDB Local only allows one GSI to be created or deleted at a time.
            for existing in existing_gsis:
                if existing["IndexName"] not in desired_names:
                    client.update_table(
                        TableName=table_name,
                        GlobalSecondaryIndexUpdates=[
                            {"Delete": {"IndexName": existing["IndexName"]}}
                        ],
                    )
                    print(f"Deleted GSI: {existing['IndexName']}")
                    wait_for_table_active(table_name)

            for gsi in global_secondary_indexes:
                if gsi["indexName"] not in existing_names:
                    attr_defs = [
                        {"AttributeName": gsi["partitionKey"], "AttributeType": "S"}
                    ]
                    if gsi.get("sortKey"):
                        attr_defs.append(
                            {"AttributeName": gsi["sortKey"], "AttributeType": "S"}
                        )
                    client.update_table(
                        TableName=table_name,
                        AttributeDefinitions=attr_defs,
                        GlobalSecondaryIndexUpdates=[
                            {
                                "Create": {
                                    "IndexName": gsi["indexName"],
                                    "KeySchema": [
                                        {
                                            "AttributeName": gsi["partitionKey"],
                                            "KeyType": "HASH",
                                        },
                                        *(
                                            [
                                                {
                                                    "AttributeName": gsi["sortKey"],
                                                    "KeyType": "RANGE",
                                                }
                                            ]
                                            if gsi.get("sortKey")
                                            else []
                                        ),
                                    ],
                                    "Projection": {"ProjectionType": "ALL"},
                                }
                            }
                        ],
                    )
                    print(f"Created GSI: {gsi['indexName']}")
                    wait_for_table_active(table_name)
            break
        if attempt == 29:
            raise
        time.sleep(1)
"
`;

exports[`py#dynamodb generator > should generate the dynamodb project > packages/common/py-dynamodb/scripts/pull_image.py 1`] = `
"import json
import subprocess
import sys

with open("config.json") as f:
    _sl = json.load(f)["serveLocal"]

container_engine = _sl["containerEngine"]
image = _sl["image"]

inspect = subprocess.run(
    [container_engine, "image", "inspect", image], capture_output=True
)
if inspect.returncode != 0:
    pull = subprocess.run([container_engine, "pull", image])
    if pull.returncode != 0:
        sys.exit(pull.returncode or 1)
"
`;

exports[`py#dynamodb generator > should generate the dynamodb project > packages/common/py-dynamodb/scripts/start_container.py 1`] = `
"import json
import signal
import subprocess
import sys

with open("config.json") as f:
    _sl = json.load(f)["serveLocal"]

container_engine = _sl["containerEngine"]
container_name = _sl["containerName"]
image = _sl["image"]
port = str(_sl["port"])


def container_exists() -> bool:
    return (
        subprocess.run(
            [container_engine, "container", "inspect", container_name],
            capture_output=True,
        ).returncode
        == 0
    )


def is_running() -> bool:
    result = subprocess.run(
        [
            container_engine,
            "container",
            "inspect",
            "-f",
            "{{.State.Running}}",
            container_name,
        ],
        capture_output=True,
        text=True,
    )
    return result.returncode == 0 and result.stdout.strip() == "true"


# Multiple dynamo table packages run serve-local in parallel sharing the same
# container. All processes stream logs, but only the one that created the
# container stops it on exit — others just detach.
created = False
run_retries = 0

while True:
    if container_exists():
        if not is_running():
            # Another process may have started it between our inspect and start — container engine start
            # exits 0 even if the container is already running, so no special-casing needed.
            start = subprocess.run([container_engine, "start", container_name])
            if start.returncode != 0:
                sys.exit(start.returncode)
        break
    run_args = [container_engine, "run"]
    if container_engine == "docker":
        run_args.append("--rm")
    run_args.extend(
        [
            "--name",
            container_name,
            "-u",
            "root",
            "-w",
            "/home/dynamodblocal",
            "-p",
            f"{port}:{port}",
            "-v",
            f"{container_name}-data:/home/dynamodblocal/data",
            "-d",
            image,
            "-jar",
            "DynamoDBLocal.jar",
            "-sharedDb",
            "-dbPath",
            "./data",
            "-port",
            port,
            "-optimizeDbBeforeStartup",
        ]
    )
    create = subprocess.run(run_args, capture_output=True, text=True)
    if create.returncode == 0:
        created = True
        break
    run_retries += 1
    if not container_exists() and run_retries > 3:
        sys.stderr.write(create.stderr)
        sys.exit(create.returncode)


logs = subprocess.Popen(
    [container_engine, "logs", "-f", container_name],
    stdin=subprocess.DEVNULL,
)

exiting = False


def cleanup(*_):
    global exiting
    if exiting:
        return
    exiting = True
    if created:
        if container_engine == "docker":
            subprocess.run(
                [container_engine, "stop", container_name], capture_output=True
            )
        else:
            subprocess.run(
                [container_engine, "rm", "-f", container_name], capture_output=True
            )
    logs.kill()
    sys.exit(0)


signal.signal(signal.SIGTERM, cleanup)
signal.signal(signal.SIGINT, cleanup)
signal.signal(signal.SIGHUP, cleanup)

logs.wait()
if not exiting:
    sys.exit(logs.returncode or 0)
"
`;

