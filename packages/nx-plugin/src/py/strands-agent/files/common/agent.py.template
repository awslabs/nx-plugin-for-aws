from contextlib import contextmanager

from strands import Agent, tool
from strands_tools import current_time


# Define a custom tool
@tool
def subtract(a: int, b: int) -> int:
    return a - b


@contextmanager
def get_agent():
    # The agent is built once on the first inbound request and kept open for
    # the lifetime of the container. AgentCore routes each runtimeSessionId
    # to a dedicated microVM, so one agent per container is the correct
    # lifetime. Connection generators (MCP / A2A) extend this function to
    # open their downstream clients inside the `yield` - those clients read
    # the captured session id lazily via :mod:`session` so they forward the
    # correct X-Amzn-Bedrock-AgentCore-Runtime-Session-Id header.
    yield Agent(
        name="<%= agentNameClassName %>",
        description="<%= agentNameClassName %> Strands Agent",
        system_prompt="""
You are a mathematical wizard.
Use your tools for mathematical tasks.
Refer to tools as your 'spellbook'.
""",
        tools=[subtract, current_time],
    )
