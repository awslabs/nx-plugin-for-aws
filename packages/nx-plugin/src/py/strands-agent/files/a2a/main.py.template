import logging
import os

from fastapi import FastAPI, Request
from strands.multiagent.a2a import A2AServer
from strands.session.file_session_manager import FileSessionManager

from .agent import get_agent
from .session import get_container_session_id, set_container_session_id

SESSION_ID_HEADER = "x-amzn-bedrock-agentcore-runtime-session-id"

logging.basicConfig(level=logging.INFO)

PORT = int(os.environ.get("PORT", "9000"))
RUNTIME_URL = os.environ.get("AGENTCORE_RUNTIME_URL", f"http://localhost:{PORT}/")

_storage_dir = os.environ.get("SESSION_STORAGE_PATH")
_session_manager: FileSessionManager | None = None


def _ensure_session_manager() -> FileSessionManager | None:
    """Lazily build the FileSessionManager once the container's
    runtimeSessionId has been captured on the first request."""
    global _session_manager
    if _storage_dir and _session_manager is None:
        _session_manager = FileSessionManager(
            session_id=get_container_session_id(),
            storage_dir=_storage_dir,
        )
        _session_manager.initialize(strands_agent)
    return _session_manager


_agent_ctx = get_agent()
strands_agent = _agent_ctx.__enter__()

app: FastAPI = A2AServer(
    agent=strands_agent,
    port=PORT,
    http_url=RUNTIME_URL,
    serve_at_root=True,
).to_fastapi_app()


@app.middleware("http")
async def capture_session_id(request: Request, call_next):
    set_container_session_id(request.headers.get(SESSION_ID_HEADER))
    _ensure_session_manager()
    return await call_next(request)


@app.get("/ping")
async def ping() -> dict:
    return {"status": "Healthy"}
