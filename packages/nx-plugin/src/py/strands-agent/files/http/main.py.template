import uvicorn
from bedrock_agentcore.runtime.models import PingStatus
from fastapi import Request
from pydantic import BaseModel

from .agent import get_agent
from .init import JsonStreamingResponse, app
from .session import set_container_session_id

SESSION_ID_HEADER = "x-amzn-bedrock-agentcore-runtime-session-id"

# AgentCore routes each runtimeSessionId to a dedicated microVM, so one agent
# instance per container is the correct lifetime. The context is entered on
# first request (after the session id has been captured) and kept open for
# the lifetime of the process - see session.py.
_agent_ctx = None
_agent = None


def _ensure_agent_started():
    global _agent_ctx, _agent
    if _agent is None:
        _agent_ctx = get_agent()
        _agent = _agent_ctx.__enter__()


class InvokeInput(BaseModel):
    message: str


class StreamChunk(BaseModel):
    content: str


async def handle_invoke(input: InvokeInput):
    """Streaming handler for agent invocation."""
    stream = _agent.stream_async(input.message)
    async for event in stream:
        print(event)
        text = event.get("event", {}).get("contentBlockDelta", {}).get("delta", {}).get("text")
        if text is not None:
            yield StreamChunk(content=text)
        elif event.get("event", {}).get("messageStop") is not None:
            yield StreamChunk(content="\n")


@app.post(
    "/invocations",
    response_class=JsonStreamingResponse,
    responses={200: JsonStreamingResponse.openapi_response(StreamChunk, "Stream of agent response chunks")},
)
async def invoke(input: InvokeInput, request: Request) -> JsonStreamingResponse:
    """Entry point for agent invocation."""
    # Capture the inbound AgentCore session id once per container so any
    # downstream MCP / A2A clients forward the same id on their outbound calls.
    set_container_session_id(request.headers.get(SESSION_ID_HEADER))
    _ensure_agent_started()
    return JsonStreamingResponse(handle_invoke(input))


@app.get("/ping")
def ping() -> str:
    # TODO: if running an async task, return PingStatus.HEALTHY_BUSY
    return PingStatus.HEALTHY


if __name__ == "__main__":
    uvicorn.run("<%- moduleName %>.<%- agentNameSnakeCase %>.main:app", port=8080)
