import logging
import uuid

from .agent import get_agent
from ag_ui_strands import StrandsAgent, create_strands_app

logging.basicConfig(level=logging.INFO)

# Template session id - padded to 33 chars to satisfy AgentCore's minimum
# session-id length when the template agent establishes its MCP client
# connection(s) at startup. Per-thread sessions use their own ids.
_TEMPLATE_SESSION_ID = f"template-{uuid.uuid4()}".ljust(33, "0")

# Create AG-UI agent wrapper. The underlying context (e.g. MCP clients)
# stays open for the lifetime of the server - we deliberately do not
# exit the context manager here.
_agent_ctx = get_agent(session_id=_TEMPLATE_SESSION_ID)
_agent = _agent_ctx.__enter__()

agui_agent = StrandsAgent(
    agent=_agent,
    name="<%= agentNameClassName %>",
    description="A Strands Agent exposed via the AG-UI protocol.",
)

# Create FastAPI app with AG-UI endpoint and health check
app = create_strands_app(agui_agent, path="/invocations")
