import logging
import os

from ag_ui.core import RunAgentInput
from ag_ui.encoder import EventEncoder
from ag_ui_strands import StrandsAgent
from ag_ui_strands.config import StrandsAgentConfig
from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse, StreamingResponse
from strands.session import SessionManager
from strands.session.file_session_manager import FileSessionManager

from .agent import get_agent
from .session import set_container_session_id

SESSION_ID_HEADER = "x-amzn-bedrock-agentcore-runtime-session-id"

logging.basicConfig(level=logging.INFO)


def _build_session_manager(input_data: RunAgentInput) -> SessionManager | None:
    """Per-thread FileSessionManager keyed on ``input_data.thread_id``."""
    storage_dir = os.environ.get("SESSION_STORAGE_PATH")
    if not storage_dir or not input_data.thread_id:
        return None
    return FileSessionManager(
        session_id=input_data.thread_id,
        storage_dir=storage_dir,
    )


# Agent construction is deferred to the first /invocations request because
# connection clients (MCP, A2A) need the inbound AgentCore session id
# captured via :mod:`session` before their transports open.
_agui_agent: StrandsAgent | None = None
_agent_ctx = None


def _get_agui_agent() -> StrandsAgent:
    global _agui_agent, _agent_ctx
    if _agui_agent is None:
        _agent_ctx = get_agent()
        _agui_agent = StrandsAgent(
            agent=_agent_ctx.__enter__(),
            name="<%= agentNameClassName %>",
            description="A Strands Agent exposed via the AG-UI protocol.",
            config=StrandsAgentConfig(
                session_manager_provider=_build_session_manager,
            ),
        )
    return _agui_agent


app = FastAPI()


@app.get("/ping")
async def ping() -> JSONResponse:
    return JSONResponse({"status": "Healthy"})


@app.post("/invocations")
async def invocations(input_data: dict, request: Request) -> StreamingResponse:
    set_container_session_id(request.headers.get(SESSION_ID_HEADER))
    agui_agent = _get_agui_agent()
    encoder = EventEncoder(
        accept=request.headers.get("accept") or "text/event-stream"
    )
    run_input = RunAgentInput(**input_data)

    async def event_generator():
        async for event in agui_agent.run(run_input):
            yield encoder.encode(event)

    return StreamingResponse(event_generator(), media_type=encoder.get_content_type())
