import logging
import uuid
from contextlib import ExitStack

from ag_ui_strands import StrandsAgent, create_strands_app
from fastapi import Request
from starlette.middleware.base import BaseHTTPMiddleware
from <%- agentConnectionModuleName %> import get_current_session_id, session_id_context

from .agent import get_agent

logging.basicConfig(level=logging.INFO)

SESSION_ID_HEADER = "x-amzn-bedrock-agentcore-runtime-session-id"

# ag_ui_strands captures tools/kwargs at StrandsAgent construction, so we
# build a fresh StrandsAgent (with fresh MCP clients) per session on demand.
_agents: dict[str, StrandsAgent] = {}
_agent_stack = ExitStack()


def _for_session() -> StrandsAgent:
    sid = get_current_session_id() or "default"
    if sid not in _agents:
        # Build the inner Agent inside the session context so its MCP clients
        # snapshot the right session on their background transport threads.
        with session_id_context(sid):
            inner = _agent_stack.enter_context(get_agent())
        _agents[sid] = StrandsAgent(
            agent=inner,
            name="<%= agentNameClassName %>",
            description="A Strands Agent exposed via the AG-UI protocol.",
        )
    return _agents[sid]


class _SessionRoutingAgent:
    """Thin proxy — dispatch ``run`` to a per-session StrandsAgent."""

    name = "<%= agentNameClassName %>"
    description = "A Strands Agent exposed via the AG-UI protocol."

    async def run(self, input_data):
        async for event in _for_session().run(input_data):
            yield event


class _SessionIdMiddleware(BaseHTTPMiddleware):
    """Bind the inbound session (or a fresh UUID) to async context."""

    async def dispatch(self, request: Request, call_next):
        session_id = request.headers.get(SESSION_ID_HEADER) or str(uuid.uuid4())
        with session_id_context(session_id):
            return await call_next(request)


app = create_strands_app(_SessionRoutingAgent(), path="/invocations")
app.add_middleware(_SessionIdMiddleware)
