import logging
from typing import Any

from ag_ui_strands import StrandsAgent, create_strands_app
from starlette.applications import Starlette
from starlette.requests import Request
from starlette.responses import JSONResponse
from starlette.routing import Mount, Route
from starlette.types import ASGIApp, Receive, Scope, Send

from .agent import get_agent
from .session import set_container_session_id

SESSION_ID_HEADER = "x-amzn-bedrock-agentcore-runtime-session-id"

logging.basicConfig(level=logging.INFO)


class _LazyStrandsApp:
    """Wraps ``create_strands_app`` so the inner Strands app is built on
    first agent invocation - never on a ``/ping`` health check.

    AgentCore routes each runtimeSessionId to a dedicated microVM, so one
    agent instance per container is the correct lifetime. Deferring
    construction to the first ``/invocations`` request means:

    1. The inbound ``X-Amzn-Bedrock-AgentCore-Runtime-Session-Id`` has been
       captured via :mod:`session` before any downstream MCP / A2A client
       reads it - outbound calls forward the correct id.
    2. ``/ping`` never triggers MCP connection opens, so health checks stay
       lightweight and do not depend on downstream services being reachable.
    """

    def __init__(self) -> None:
        self._inner: ASGIApp | None = None
        self._agent_ctx: Any = None

    async def __call__(self, scope: Scope, receive: Receive, send: Send) -> None:
        # Capture the inbound AgentCore session id first so downstream MCP / A2A
        # clients forward it on their outbound calls.
        if scope["type"] == "http":
            headers = dict(
                (k.decode("latin-1"), v.decode("latin-1"))
                for k, v in scope.get("headers", [])
            )
            set_container_session_id(headers.get(SESSION_ID_HEADER))

        if self._inner is None:
            self._agent_ctx = get_agent()
            agui_agent = StrandsAgent(
                agent=self._agent_ctx.__enter__(),
                name="<%= agentNameClassName %>",
                description="A Strands Agent exposed via the AG-UI protocol.",
            )
            self._inner = create_strands_app(agui_agent, path="/invocations", ping_path=None)

        await self._inner(scope, receive, send)


async def _ping(request: Request) -> JSONResponse:
    return JSONResponse({"status": "Healthy"})


_lazy_invocations = _LazyStrandsApp()

app = Starlette(
    routes=[
        Route("/ping", _ping, methods=["GET"]),
        Mount("/", app=_lazy_invocations),
    ]
)
