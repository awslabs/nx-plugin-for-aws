import logging
import os

from ag_ui.core import RunAgentInput
from ag_ui_strands import StrandsAgent, create_strands_app
from ag_ui_strands.config import StrandsAgentConfig
from strands.session import SessionManager
from strands.session.file_session_manager import FileSessionManager

from .agent import get_agent
from .session import set_container_session_id

SESSION_ID_HEADER = "x-amzn-bedrock-agentcore-runtime-session-id"

logging.basicConfig(level=logging.INFO)


def _build_session_manager(input_data: RunAgentInput) -> SessionManager | None:
    """Per-thread FileSessionManager keyed on ``input_data.thread_id``."""
    storage_dir = os.environ.get("SESSION_STORAGE_PATH")
    if not storage_dir or not input_data.thread_id:
        return None
    return FileSessionManager(
        session_id=input_data.thread_id,
        storage_dir=storage_dir,
    )


# One agent per container (AgentCore maps one runtimeSessionId to one
# microVM). MCP / A2A connection clients rely on the context staying open
# for the process lifetime, so we enter it here and never close it.
_agent_ctx = get_agent()
strands_agent = _agent_ctx.__enter__()

agui_agent = StrandsAgent(
    agent=strands_agent,
    name="<%= agentNameClassName %>",
    description="A Strands Agent exposed via the AG-UI protocol.",
    config=StrandsAgentConfig(
        session_manager_provider=_build_session_manager,
    ),
)

app = create_strands_app(agui_agent, path="/invocations")


@app.middleware("http")
async def capture_session_id(request, call_next):
    set_container_session_id(request.headers.get(SESSION_ID_HEADER))
    return await call_next(request)
