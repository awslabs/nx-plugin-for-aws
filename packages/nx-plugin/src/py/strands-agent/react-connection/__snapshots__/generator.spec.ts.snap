exports[`py strands agent react connection generator > should generate provider component > TestAgentProvider.tsx 1`] = `
"import { createContext, FC, PropsWithChildren, useMemo } from 'react';
import { TestAgent } from '../generated/test-agent/client.gen';
import { TestAgentOptionsProxy } from '../generated/test-agent/options-proxy.gen';
import { useRuntimeConfig } from '../hooks/useRuntimeConfig';
import { useSigV4 } from '../hooks/useSigV4';

/**
 * Build an HTTP URL from a Bedrock AgentCore Runtime ARN
 */
function buildAgentCoreHttpUrl(agentRuntimeArn: string): string {
  const region = agentRuntimeArn.split(':')[3];
  return \`https://bedrock-agentcore.\${region}.amazonaws.com/runtimes/\${encodeURIComponent(agentRuntimeArn)}\`;
}

export const TestAgentContext = createContext<
  TestAgentOptionsProxy | undefined
>(undefined);

export const TestAgentClientContext = createContext<TestAgent | undefined>(
  undefined,
);

const useCreateTestAgentClient = (): TestAgent => {
  const runtimeConfig = useRuntimeConfig();
  const agentRuntimeValue = runtimeConfig.agentRuntimes.TestAgent;
  const apiUrl = agentRuntimeValue.startsWith('arn:')
    ? buildAgentCoreHttpUrl(agentRuntimeValue)
    : agentRuntimeValue;
  const sigv4Client = useSigV4();
  return useMemo(
    () =>
      new TestAgent({
        url: apiUrl,
        fetch: sigv4Client.fetch,
      }),
    [apiUrl, sigv4Client],
  );
};

export const TestAgentProvider: FC<PropsWithChildren> = ({ children }) => {
  const client = useCreateTestAgentClient();
  const optionsProxy = useMemo(
    () => new TestAgentOptionsProxy({ client }),
    [client],
  );

  return (
    <TestAgentClientContext.Provider value={client}>
      <TestAgentContext.Provider value={optionsProxy}>
        {children}
      </TestAgentContext.Provider>
    </TestAgentClientContext.Provider>
  );
};

export default TestAgentProvider;
"
`;

exports[`py strands agent react connection generator > should handle Cognito auth option > TestAgentProvider-Cognito.tsx 1`] = `
"import { createContext, FC, PropsWithChildren, useMemo } from 'react';
import { TestAgent } from '../generated/test-agent/client.gen';
import { TestAgentOptionsProxy } from '../generated/test-agent/options-proxy.gen';
import { useRuntimeConfig } from '../hooks/useRuntimeConfig';
import { useAuth } from 'react-oidc-context';

/**
 * Build an HTTP URL from a Bedrock AgentCore Runtime ARN
 */
function buildAgentCoreHttpUrl(agentRuntimeArn: string): string {
  const region = agentRuntimeArn.split(':')[3];
  return \`https://bedrock-agentcore.\${region}.amazonaws.com/runtimes/\${encodeURIComponent(agentRuntimeArn)}\`;
}

export const TestAgentContext = createContext<
  TestAgentOptionsProxy | undefined
>(undefined);

export const TestAgentClientContext = createContext<TestAgent | undefined>(
  undefined,
);

const useCreateTestAgentClient = (): TestAgent => {
  const runtimeConfig = useRuntimeConfig();
  const agentRuntimeValue = runtimeConfig.agentRuntimes.TestAgent;
  const apiUrl = agentRuntimeValue.startsWith('arn:')
    ? buildAgentCoreHttpUrl(agentRuntimeValue)
    : agentRuntimeValue;
  const auth = useAuth();
  const user = auth?.user;
  const cognitoClient: typeof fetch = (url, init) => {
    const headers = new Headers(init?.headers);
    headers.set('Authorization', \`Bearer \${user?.id_token}\`);
    return fetch(url, { ...init, headers });
  };
  return useMemo(
    () =>
      new TestAgent({
        url: apiUrl,
        fetch: cognitoClient,
      }),
    [apiUrl, cognitoClient],
  );
};

export const TestAgentProvider: FC<PropsWithChildren> = ({ children }) => {
  const client = useCreateTestAgentClient();
  const optionsProxy = useMemo(
    () => new TestAgentOptionsProxy({ client }),
    [client],
  );

  return (
    <TestAgentClientContext.Provider value={client}>
      <TestAgentContext.Provider value={optionsProxy}>
        {children}
      </TestAgentContext.Provider>
    </TestAgentClientContext.Provider>
  );
};

export default TestAgentProvider;
"
`;

