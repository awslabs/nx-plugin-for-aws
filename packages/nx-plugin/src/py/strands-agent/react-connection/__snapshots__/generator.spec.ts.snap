exports[`py strands agent react connection generator - AG-UI themed CopilotKit > should vend the shadcn-themed copilot components and shared shadcn primitives when uxProvider is Shadcn > shadcn-theme-index.tsx 1`] = `
"import {
  CopilotChat as CopilotChatBase,
  CopilotSidebar as CopilotSidebarBase,
  CopilotPopup as CopilotPopupBase,
  type CopilotChatProps,
  type CopilotSidebarProps,
  type CopilotPopupProps,
} from '@copilotkit/react-core/v2';
import { ShadcnAssistantMessage } from './ShadcnAssistantMessage';
import { ShadcnUserMessage } from './ShadcnUserMessage';
import { ShadcnChatInput } from './ShadcnChatInput';
import { ShadcnCursor } from './ShadcnCursor';

/**
 * Slot overrides that style the CopilotKit chat components using shadcn/ui
 * primitives (\`Avatar\`, \`Button\`, \`Textarea\`, ...) plus Tailwind prose
 * styling. Instantiate the re-exported {@link CopilotChat},
 * {@link CopilotSidebar} or {@link CopilotPopup} from this module to pick up
 * the theme automatically. Per-chat slot overrides still win because the
 * theme is passed as defaults before the caller's props.
 *
 * CopilotKit types the slot values against the default component (with its
 * static sub-components attached), so replacement FCs are cast to \`any\` when
 * assigned to the theme config.
 */
/* eslint-disable @typescript-eslint/no-explicit-any */
export const shadcnCopilotTheme = {
  messageView: {
    assistantMessage: ShadcnAssistantMessage as any,
    userMessage: ShadcnUserMessage as any,
    cursor: ShadcnCursor as any,
    className: 'flex flex-col gap-3 px-4 py-6',
  },
  input: ShadcnChatInput as any,
} as const;
/* eslint-enable @typescript-eslint/no-explicit-any */

export const CopilotChat = (props: CopilotChatProps) => (
  <CopilotChatBase {...shadcnCopilotTheme} {...props} />
);

export const CopilotSidebar = (props: CopilotSidebarProps) => (
  <CopilotSidebarBase {...shadcnCopilotTheme} {...props} />
);

export const CopilotPopup = (props: CopilotPopupProps) => (
  <CopilotPopupBase {...shadcnCopilotTheme} {...props} />
);

export {
  ShadcnAssistantMessage,
  ShadcnUserMessage,
  ShadcnChatInput,
  ShadcnCursor,
};
"
`;
