import os
from urllib.parse import quote

from strands.agent.a2a_agent import A2AAgent

from <%- agentConnectionModuleName %>.core.agentcore_a2a_client import AgentCoreA2aClient
from <%- agentConnectionModuleName %>.core.runtime_config import (
    get_connected_agent_runtime_arn,
)


class <%- targetAgentClassName %>Client:
    """Client for the <%- targetAgentClassName %> A2A agent."""

    @staticmethod
    def create() -> A2AAgent:
        if os.environ.get("SERVE_LOCAL") == "true":
            return AgentCoreA2aClient.without_auth(
                "http://localhost:<%- targetAgentPort %>/"
            )
        agent_runtime_arn = get_connected_agent_runtime_arn("<%- targetAgentClassName %>")
        region = agent_runtime_arn.split(":")[3]
        encoded_arn = quote(agent_runtime_arn, safe="")
        url = (
            f"https://bedrock-agentcore.{region}.amazonaws.com/runtimes/"
            f"{encoded_arn}/invocations/"
        )
        return AgentCoreA2aClient.with_iam_auth(url, agent_runtime_arn)
