exports[`ts#rdb mcp-server-connection generator > should support multiple rdb connections 1`] = `
"import { getPrisma as getMysqlDb } from 'mysql-db';
import { getPrisma as getPostgresDb } from 'postgres-db';
import { McpServer } from '@modelcontextprotocol/sdk/server/mcp.js';

export const createServer = ({
  postgresDb,
  mysqlDb,
}: {
  postgresDb: Awaited<ReturnType<typeof getPostgresDb>>;
  mysqlDb: Awaited<ReturnType<typeof getMysqlDb>>;
}) => {
  const server = new McpServer({
    name: 'my-service',
    version: '1.0.0',
  });

  return server;
};
"
`;

exports[`ts#rdb mcp-server-connection generator > should support multiple rdb connections 2`] = `
"#!/usr/bin/env node
import { getPrisma as getMysqlDb } from 'mysql-db';
import { getPrisma as getPostgresDb } from 'postgres-db';
import { createServer } from './server.js';
import { StreamableHTTPServerTransport } from '@modelcontextprotocol/sdk/server/streamableHttp.js';
import express, { Request, Response } from 'express';

const PORT = parseInt(process.env.PORT || '8000');
const app = express();
app.use(express.json());

app.post('/mcp', async (req: Request, res: Response) => {
  try {
    const postgresDb = await getPostgresDb();
    const mysqlDb = await getMysqlDb();
    const server = createServer({ postgresDb, mysqlDb });
    const transport = new StreamableHTTPServerTransport({
      sessionIdGenerator: undefined,
    });
    await server.connect(transport);
  } catch (error) {
    console.error(error);
  }
});
"
`;

exports[`ts#rdb mcp-server-connection generator > should support multiple rdb connections 3`] = `
"#!/usr/bin/env node
import { getPrisma as getMysqlDb } from 'mysql-db';
import { getPrisma as getPostgresDb } from 'postgres-db';
import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';
import { createServer } from './server.js';

export const startMcpServer = async () => {
  const transport = new StdioServerTransport();
  const postgresDb = await getPostgresDb();
  const mysqlDb = await getMysqlDb();
  await createServer({ postgresDb, mysqlDb }).connect(transport);
};
"
`;
