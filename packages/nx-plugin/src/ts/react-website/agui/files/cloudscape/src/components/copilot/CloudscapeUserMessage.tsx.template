import type { FC } from 'react';
import type { CopilotChatUserMessageProps } from '@copilotkit/react-core/v2';
import ChatBubble from '@cloudscape-design/chat-components/chat-bubble';
import Avatar from '@cloudscape-design/chat-components/avatar';

/**
 * Flatten a user message's potentially-structured content into a string for
 * display. Mirrors CopilotKit's internal `flattenUserMessageContent` so the
 * bubble renders the same text the default component would have.
 */
const flattenContent = (
  content: CopilotChatUserMessageProps['message']['content'],
): string => {
  if (!content) return '';
  if (typeof content === 'string') return content;
  return content
    .filter(
      (part): part is { type: 'text'; text: string } =>
        !!part &&
        typeof part === 'object' &&
        'type' in part &&
        (part as { type?: unknown }).type === 'text' &&
        'text' in part &&
        typeof (part as { text?: unknown }).text === 'string',
    )
    .map((part) => part.text)
    .join('\n');
};

/**
 * User message rendered with the Cloudscape outgoing {@link ChatBubble}. The
 * content is rendered as plain text (wrapped in `pre-wrap` so newlines are
 * preserved) rather than Markdown — matching CopilotKit's default user
 * rendering behaviour.
 */
export const CloudscapeUserMessage: FC<CopilotChatUserMessageProps> = ({
  message,
}) => (
  <ChatBubble
    ariaLabel="Your message"
    type="outgoing"
    avatar={<Avatar ariaLabel="You" tooltipText="You" initials="You" />}
  >
    <div style={{ whiteSpace: 'pre-wrap', wordBreak: 'break-word' }}>
      {flattenContent(message.content)}
    </div>
  </ChatBubble>
);

export default CloudscapeUserMessage;
