import { useState, type FC } from 'react';
import type { CopilotChatInputProps } from '@copilotkit/react-core/v2';
import PromptInput from '@cloudscape-design/components/prompt-input';

/**
 * Replaces the default CopilotKit chat input with a Cloudscape
 * {@link PromptInput}. The action button toggles between "send" and "stop"
 * depending on the CopilotKit {@code isRunning} flag.
 */
export const CloudscapeChatInput: FC<CopilotChatInputProps> = ({
  value,
  onChange,
  onSubmitMessage,
  onStop,
  isRunning,
  autoFocus,
  mode,
}) => {
  const [internalValue, setInternalValue] = useState('');
  const currentValue = value ?? internalValue;
  const disabled = mode === 'processing';

  const handleChange = (next: string) => {
    onChange?.(next);
    if (value === undefined) {
      setInternalValue(next);
    }
  };

  const handleAction = () => {
    if (isRunning) {
      onStop?.();
      return;
    }
    const trimmed = currentValue.trim();
    if (!trimmed) return;
    onSubmitMessage?.(trimmed);
    if (value === undefined) {
      setInternalValue('');
    }
  };

  return (
    <PromptInput
      value={currentValue}
      onChange={({ detail }) => handleChange(detail.value)}
      onAction={handleAction}
      actionButtonAriaLabel={isRunning ? 'Stop' : 'Send message'}
      actionButtonIconName={isRunning ? 'close' : 'send'}
      ariaLabel="Chat input"
      placeholder="Ask me anything..."
      autoFocus={autoFocus}
      disabled={disabled}
      maxRows={6}
    />
  );
};

export default CloudscapeChatInput;
