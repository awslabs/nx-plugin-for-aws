import { useState } from 'react';
import {
  CopilotChatInput,
  type CopilotChatInputProps,
} from '@copilotkit/react-core/v2';
import PromptInput from '@cloudscape-design/components/prompt-input';

const CloudscapeChatInputImpl = ({
  value,
  onChange,
  onSubmitMessage,
  onStop,
  isRunning,
  autoFocus,
  mode,
}: CopilotChatInputProps) => {
  const [internalValue, setInternalValue] = useState('');
  const currentValue = value ?? internalValue;
  const disabled = mode === 'processing';

  const handleChange = (next: string) => {
    onChange?.(next);
    if (value === undefined) {
      setInternalValue(next);
    }
  };

  const handleAction = () => {
    if (isRunning) {
      onStop?.();
      return;
    }
    const trimmed = currentValue.trim();
    if (!trimmed) return;
    onSubmitMessage?.(trimmed);
    if (value === undefined) {
      setInternalValue('');
    }
  };

  return (
    <div className="copilotkit-cloudscape-input">
      <PromptInput
        value={currentValue}
        onChange={({ detail }) => handleChange(detail.value)}
        onAction={handleAction}
        actionButtonAriaLabel={isRunning ? 'Stop' : 'Send message'}
        actionButtonIconName={isRunning ? 'close' : 'send'}
        ariaLabel="Chat input"
        placeholder="Ask me anything..."
        autoFocus={autoFocus}
        disabled={disabled}
        minRows={2}
        maxRows={6}
      />
    </div>
  );
};

export const CloudscapeChatInput = Object.assign(
  CloudscapeChatInputImpl,
  CopilotChatInput,
);

export default CloudscapeChatInput;
