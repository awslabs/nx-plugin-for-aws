import {
  CopilotChatAssistantMessage,
  CopilotChatToolCallsView,
} from '@copilotkit/react-core/v2';
import type { CopilotChatAssistantMessageProps } from '@copilotkit/react-core/v2';
import ChatBubble from '@cloudscape-design/chat-components/chat-bubble';
import Avatar from '@cloudscape-design/chat-components/avatar';
import ButtonGroup from '@cloudscape-design/components/button-group';
import StatusIndicator from '@cloudscape-design/components/status-indicator';

const CloudscapeAssistantMessageImpl = ({
  message,
  messages,
}: CopilotChatAssistantMessageProps) => {
  const handleCopy = () => {
    if (typeof message.content === 'string') {
      void navigator.clipboard?.writeText(message.content);
    }
  };

  return (
    <ChatBubble
      ariaLabel="Assistant message"
      type="incoming"
      avatar={
        <Avatar
          color="gen-ai"
          iconName="gen-ai"
          ariaLabel="Assistant"
          tooltipText="Assistant"
        />
      }
      actions={
        <ButtonGroup
          ariaLabel="Chat bubble actions"
          variant="icon"
          onItemClick={({ detail }) => {
            if (detail.id === 'copy') handleCopy();
          }}
          items={[
            {
              type: 'icon-button',
              id: 'copy',
              iconName: 'copy',
              text: 'Copy',
              popoverFeedback: (
                <StatusIndicator type="success">
                  Message copied
                </StatusIndicator>
              ),
            },
          ]}
        />
      }
    >
      <CopilotChatAssistantMessage.MarkdownRenderer
        content={message.content ?? ''}
      />
      {message.toolCalls && message.toolCalls.length > 0 && (
        <CopilotChatToolCallsView message={message} messages={messages} />
      )}
    </ChatBubble>
  );
};

export const CloudscapeAssistantMessage = Object.assign(
  CloudscapeAssistantMessageImpl,
  CopilotChatAssistantMessage,
);

export default CloudscapeAssistantMessage;
