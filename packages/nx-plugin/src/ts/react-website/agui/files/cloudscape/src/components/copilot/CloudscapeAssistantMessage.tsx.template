import type { FC } from 'react';
import { CopilotChatAssistantMessage } from '@copilotkit/react-core/v2';
import type { CopilotChatAssistantMessageProps } from '@copilotkit/react-core/v2';
import ChatBubble from '@cloudscape-design/chat-components/chat-bubble';
import Avatar from '@cloudscape-design/chat-components/avatar';
import ButtonGroup from '@cloudscape-design/components/button-group';
import StatusIndicator from '@cloudscape-design/components/status-indicator';

type FeedbackId = 'helpful' | 'not-helpful' | 'copy' | 'regenerate';

/**
 * Assistant message rendered with the Cloudscape {@link ChatBubble} and a
 * {@link ButtonGroup} action toolbar. The message body is rendered using the
 * CopilotKit {@link CopilotChatAssistantMessage.MarkdownRenderer} directly,
 * which keeps GFM / KaTeX / code highlighting without inheriting the
 * default CopilotKit message container styling that would clash with the
 * Cloudscape ChatBubble.
 */
export const CloudscapeAssistantMessage: FC<
  CopilotChatAssistantMessageProps
> = ({ message, onThumbsUp, onThumbsDown, onRegenerate }) => {
  const handleAction = (id: FeedbackId) => {
    if (!message) return;
    switch (id) {
      case 'helpful':
        onThumbsUp?.(message);
        break;
      case 'not-helpful':
        onThumbsDown?.(message);
        break;
      case 'copy':
        if (typeof message.content === 'string') {
          void navigator.clipboard?.writeText(message.content);
        }
        break;
      case 'regenerate':
        onRegenerate?.(message);
        break;
    }
  };

  return (
    <ChatBubble
      ariaLabel="Assistant message"
      type="incoming"
      avatar={
        <Avatar
          color="gen-ai"
          iconName="gen-ai"
          ariaLabel="Assistant"
          tooltipText="Assistant"
        />
      }
      actions={
        <ButtonGroup
          ariaLabel="Chat bubble actions"
          variant="icon"
          onItemClick={({ detail }) => handleAction(detail.id as FeedbackId)}
          items={[
            {
              type: 'group',
              text: 'Feedback',
              items: [
                {
                  type: 'icon-button',
                  id: 'helpful',
                  iconName: 'thumbs-up',
                  text: 'Helpful',
                },
                {
                  type: 'icon-button',
                  id: 'not-helpful',
                  iconName: 'thumbs-down',
                  text: 'Not helpful',
                },
              ],
            },
            {
              type: 'icon-button',
              id: 'copy',
              iconName: 'copy',
              text: 'Copy',
              popoverFeedback: (
                <StatusIndicator type="success">
                  Message copied
                </StatusIndicator>
              ),
            },
            {
              type: 'icon-button',
              id: 'regenerate',
              iconName: 'refresh',
              text: 'Regenerate',
            },
          ]}
        />
      }
    >
      <CopilotChatAssistantMessage.MarkdownRenderer
        content={message.content ?? ''}
      />
    </ChatBubble>
  );
};

export default CloudscapeAssistantMessage;
