import type { FC } from 'react';
import {
  CopilotChatAssistantMessage,
  CopilotChatToolCallsView,
} from '@copilotkit/react-core/v2';
import type { CopilotChatAssistantMessageProps } from '@copilotkit/react-core/v2';
import {
  Copy,
  RefreshCw,
  Sparkles,
  ThumbsDown,
  ThumbsUp,
} from 'lucide-react';
import {
  Avatar,
  AvatarFallback,
} from '<%= scopeAlias %>common-shadcn/components/ui/avatar';
import { Button } from '<%= scopeAlias %>common-shadcn/components/ui/button';
import { cn } from '<%= scopeAlias %>common-shadcn/lib/utils';

/**
 * Assistant message rendered with a shadcn/ui {@link Avatar} and a subdued
 * card-style bubble. Markdown is rendered using CopilotKit's default
 * {@link CopilotChatAssistantMessage.MarkdownRenderer} inside a prose
 * container so code blocks, tables, KaTeX etc. continue to work without
 * inheriting the default CopilotKit bubble styling that would clash with
 * shadcn tokens. A small hover toolbar provides copy / thumbs / regenerate.
 */
export const ShadcnAssistantMessage: FC<CopilotChatAssistantMessageProps> = ({
  message,
  onThumbsUp,
  onThumbsDown,
  onRegenerate,
}) => {
  const hasContent = !!(message.content && message.content.trim().length > 0);

  const handleCopy = () => {
    if (typeof message.content === 'string') {
      void navigator.clipboard?.writeText(message.content);
    }
  };

  return (
    <div className="group flex items-start gap-3 py-2">
      <Avatar className="bg-primary/10 border-primary/20 mt-0.5 border">
        <AvatarFallback className="bg-transparent">
          <Sparkles className="text-primary size-4" />
        </AvatarFallback>
      </Avatar>
      <div className="flex min-w-0 flex-1 flex-col gap-1.5">
        <div
          className={cn(
            'bg-muted/60 text-foreground rounded-2xl rounded-tl-sm px-4 py-2.5',
            'prose prose-sm dark:prose-invert max-w-none',
            'prose-p:my-1 prose-headings:my-2 prose-pre:my-2 prose-pre:bg-background/80',
            'prose-code:rounded prose-code:bg-background/60 prose-code:px-1 prose-code:py-0.5',
            'prose-code:before:content-[""] prose-code:after:content-[""]',
          )}
        >
          <CopilotChatAssistantMessage.MarkdownRenderer
            content={message.content ?? ''}
          />
        </div>
        {message.toolCalls && message.toolCalls.length > 0 && (
          <CopilotChatToolCallsView message={message} />
        )}
        {hasContent && (
          <div className="text-muted-foreground flex items-center gap-0.5 opacity-0 transition-opacity group-hover:opacity-100">
            <Button
              type="button"
              variant="ghost"
              size="icon"
              className="size-7"
              aria-label="Copy message"
              onClick={handleCopy}
            >
              <Copy className="size-3.5" />
            </Button>
            {onThumbsUp && (
              <Button
                type="button"
                variant="ghost"
                size="icon"
                className="size-7"
                aria-label="Helpful"
                onClick={() => onThumbsUp(message)}
              >
                <ThumbsUp className="size-3.5" />
              </Button>
            )}
            {onThumbsDown && (
              <Button
                type="button"
                variant="ghost"
                size="icon"
                className="size-7"
                aria-label="Not helpful"
                onClick={() => onThumbsDown(message)}
              >
                <ThumbsDown className="size-3.5" />
              </Button>
            )}
            {onRegenerate && (
              <Button
                type="button"
                variant="ghost"
                size="icon"
                className="size-7"
                aria-label="Regenerate"
                onClick={() => onRegenerate(message)}
              >
                <RefreshCw className="size-3.5" />
              </Button>
            )}
          </div>
        )}
      </div>
    </div>
  );
};

export default ShadcnAssistantMessage;
