import type { FC } from 'react';
import { cn } from '<%= scopeAlias %>common-shadcn/lib/utils';

/**
 * Subtle typing indicator — three pulsing dots that match the shadcn/ui
 * muted foreground palette.
 */
export const ShadcnCursor: FC = () => (
  <div
    role="status"
    aria-label="Generating response"
    className="flex items-center gap-1 px-4 py-2"
  >
    {[0, 1, 2].map((i) => (
      <span
        key={i}
        className={cn(
          'bg-muted-foreground/60 size-1.5 rounded-full',
          'animate-bounce',
        )}
        style={{ animationDelay: `${i * 120}ms` }}
      />
    ))}
  </div>
);

export default ShadcnCursor;
