import type { FC } from 'react';
import type {
  CopilotChatUserMessageProps,
  UserMessage,
} from '@copilotkit/react-core/v2';
import { User } from 'lucide-react';
import {
  Avatar,
  AvatarFallback,
} from '<%= scopeAlias %>common-shadcn/components/ui/avatar';

/**
 * Flatten a user message's potentially-structured content into a plain
 * string for display. Mirrors CopilotKit's internal
 * `flattenUserMessageContent` so the bubble shows the same text the default
 * component would render.
 */
const flattenContent = (content: UserMessage['content']): string => {
  if (!content) return '';
  if (typeof content === 'string') return content;
  return content
    .filter(
      (part): part is { type: 'text'; text: string } =>
        !!part &&
        typeof part === 'object' &&
        'type' in part &&
        (part as { type?: unknown }).type === 'text' &&
        'text' in part &&
        typeof (part as { text?: unknown }).text === 'string',
    )
    .map((part) => part.text)
    .join('\n');
};

/**
 * User message rendered with a shadcn/ui {@link Avatar} and a right-aligned
 * primary bubble. Content is rendered as plain text (`pre-wrap`) rather than
 * Markdown — consistent with CopilotKit's default user renderer.
 */
export const ShadcnUserMessage: FC<CopilotChatUserMessageProps> = ({
  message,
}) => (
  <div className="flex items-start justify-end gap-3 py-2">
    <div className="flex min-w-0 max-w-[85%] flex-col items-end gap-1.5">
      <div className="bg-primary text-primary-foreground rounded-2xl rounded-tr-sm px-4 py-2.5 whitespace-pre-wrap break-words">
        {flattenContent(message.content)}
      </div>
    </div>
    <Avatar className="bg-secondary mt-0.5">
      <AvatarFallback className="bg-transparent">
        <User className="text-secondary-foreground size-4" />
      </AvatarFallback>
    </Avatar>
  </div>
);

export default ShadcnUserMessage;
