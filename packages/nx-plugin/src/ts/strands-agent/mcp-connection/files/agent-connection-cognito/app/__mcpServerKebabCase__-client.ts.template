import { McpClient } from '@strands-agents/sdk';
import { AgentCoreMcpClient } from '../core/agentcore-mcp-client.js';
import { AgentCoreIdentityTokenProvider } from '../core/agentcore-identity-token-provider.js';
import { StreamableHTTPClientTransport } from '@modelcontextprotocol/sdk/client/streamableHttp.js';
import { getAppConfig } from '@aws-lambda-powertools/parameters/appconfig';

export interface <%- mcpServerClassName %>ClientContext {
  sessionId: string;
  workloadAccessToken?: string;
}

/**
 * Client for connecting to the <%- mcpServerClassName %> MCP server.
 *
 * In deployed mode: resolves the AgentCore runtime ARN from runtime config
 * and uses JWT-authenticated AgentCore transport via AgentCore Identity.
 *
 * In local mode (SERVE_LOCAL env var set): connects directly
 * to the local MCP server via Streamable HTTP.
 */
export class <%- mcpServerClassName %>Client {
  static async create(ctx: <%- mcpServerClassName %>ClientContext): Promise<McpClient> {
    if (process.env.SERVE_LOCAL === 'true') {
      // Local development: connect directly via Streamable HTTP
      const transport = new StreamableHTTPClientTransport(
        new URL('http://localhost:<%- mcpServerPort %>/mcp'),
      );
      return new McpClient({ transport });
    }

    // Deployed: resolve ARN and credentials from runtime config
    const config = (await getAppConfig('connection', {
      application: process.env.RUNTIME_CONFIG_APP_ID!,
      environment: 'default',
      transform: 'json',
    })) as Record<string, any>;

    const m2mConfig = config.cognitoM2M?.['<%- mcpServerClassName %>'];
    const tokenProvider = new AgentCoreIdentityTokenProvider({
      providerName: m2mConfig.credentialProviderName,
      scope: m2mConfig.scope,
      workloadAccessToken: ctx.workloadAccessToken!,
    });

    return AgentCoreMcpClient.withJwtAuth({
      agentRuntimeArn: config.agentRuntimes.<%- mcpServerClassName %>,
      accessTokenProvider: () => tokenProvider.getToken(),
      sessionId: ctx.sessionId,
    });
  }
}
