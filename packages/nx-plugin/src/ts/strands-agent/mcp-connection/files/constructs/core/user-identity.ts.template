import { CfnOutput, Duration, Stack } from 'aws-cdk-lib';
import {
  AccountRecovery,
  Mfa,
  OAuthScope,
  UserPool,
  UserPoolClient,
  UserPoolDomain,
  UserPoolResourceServer,
} from 'aws-cdk-lib/aws-cognito';
import { Construct } from 'constructs';
import { RuntimeConfig } from './runtime-config.js';

/**
 * Creates a Cognito UserPool with an M2M app client and resource server
 * for agent-to-MCP server authentication.
 */
export class UserIdentity extends Construct {
  public readonly userPool: UserPool;
  public readonly userPoolDomain: UserPoolDomain;
  public readonly m2mClient: UserPoolClient;
  public readonly userClient: UserPoolClient;
  public readonly resourceServer: UserPoolResourceServer;
  public readonly scope: string;
  public readonly domainPrefix: string;

  constructor(scope: Construct, id: string) {
    super(scope, id);

    const account = Stack.of(this).account;
    const region = Stack.of(this).region;

    this.userPool = new UserPool(this, 'UserPool', {
      deletionProtection: false,
      passwordPolicy: {
        minLength: 8,
        requireLowercase: true,
        requireUppercase: true,
        requireDigits: true,
        requireSymbols: true,
        tempPasswordValidity: Duration.days(3),
      },
      mfa: Mfa.OFF,
      signInCaseSensitive: false,
      signInAliases: { username: true, email: true },
      accountRecovery: AccountRecovery.EMAIL_ONLY,
      selfSignUpEnabled: false,
    });

    this.domainPrefix = `mcp-auth-${account}`;
    this.userPoolDomain = this.userPool.addDomain('UserPoolDomain', {
      cognitoDomain: {
        domainPrefix: this.domainPrefix,
      },
    });

    // Resource server with invoke scope
    const resourceServerIdentifier = `mcp-${account}`;
    this.scope = `${resourceServerIdentifier}/invoke`;

    this.resourceServer = this.userPool.addResourceServer('McpResourceServer', {
      identifier: resourceServerIdentifier,
      scopes: [
        {
          scopeName: 'invoke',
          scopeDescription: 'Invoke MCP server runtimes',
        },
      ],
    });

    // M2M app client with client_credentials grant
    this.m2mClient = this.userPool.addClient('M2MClient', {
      generateSecret: true,
      oAuth: {
        flows: { clientCredentials: true },
        scopes: [OAuthScope.custom(this.scope)],
      },
    });
    this.m2mClient.node.addDependency(this.resourceServer);

    // User-facing app client (for JWT inbound auth on agent runtimes)
    this.userClient = this.userPool.addClient('UserClient', {
      generateSecret: false,
      authFlows: {
        userPassword: true,
      },
    });

    // Publish cognito props to runtime config
    RuntimeConfig.ensure(this).set('connection', 'cognitoProps', {
      region,
      userPoolId: this.userPool.userPoolId,
    });

    new CfnOutput(this, 'UserPoolId', {
      value: this.userPool.userPoolId,
    });

    new CfnOutput(this, 'M2MClientId', {
      value: this.m2mClient.userPoolClientId,
    });

    new CfnOutput(this, 'UserClientId', {
      value: this.userClient.userPoolClientId,
    });
  }
}
