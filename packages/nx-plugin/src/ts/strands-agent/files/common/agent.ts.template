import { Agent, FileStorage, SessionManager, tool } from '@strands-agents/sdk';
import { z } from 'zod';
import { getContainerSessionId } from './session.js';

const multiply = tool({
  name: 'Multiply',
  description: 'Multiply two numbers',
  inputSchema: z.object({
    a: z.number(),
    b: z.number(),
  }),
  callback: ({ a, b }) => a * b,
});

/**
 * Build the agent for this container.
 *
 * Called once on container startup. Every AgentCore microVM services a
 * single `runtimeSessionId`, so a single agent instance per container is
 * the correct lifetime. Downstream MCP / A2A clients read the captured
 * session id from `./session` lazily, so they still forward the correct
 * `X-Amzn-Bedrock-AgentCore-Runtime-Session-Id` on their outbound calls.
 *
 * When AgentCore-managed session storage is attached to the runtime, the
 * mount path is exposed via `SESSION_STORAGE_PATH`. Wiring a
 * `SessionManager` backed by `FileStorage` at that path lets the agent
 * resume the full conversation history after a stop/resume cycle. Absent
 * the env var (e.g. local serve), the agent runs in-memory only.
 */
export const getAgent = async (): Promise<Agent> => {
  const sessionStorageDir = process.env.SESSION_STORAGE_PATH;
  const sessionManager = sessionStorageDir
    ? new SessionManager({
        sessionId: getContainerSessionId(),
        storage: { snapshot: new FileStorage(sessionStorageDir) },
      })
    : undefined;

  return new Agent({
    systemPrompt: `You are a mathematical wizard.
  Use your tools for mathematical tasks.
  Refer to tools as your 'spellbook'.`,
    tools: [multiply],
    sessionManager,
  });
};
