import { initTRPC } from '@trpc/server';

/**
 * Per-request tRPC context. `sessionId` carries the value of the inbound
 * `X-Amzn-Bedrock-AgentCore-Runtime-Session-Id` header so procedures can
 * tag downstream work with the real container session id. The module-level
 * `session.ts` store is populated by the transport layer (see `index.ts`)
 * before any procedure runs.
 */
export interface Context {
  sessionId: string | undefined;
}

export const t = initTRPC.context<Context>().create();

export const publicProcedure = t.procedure;
