import type { StructuredToolInterface } from '@langchain/core/tools';
import { AgentCoreMcpClientLangChain } from '../core/agentcore-mcp-client-langchain.js';
import { getAgentCoreRuntimeConfig } from '../core/runtime-config.js';

/** LangChain client for the <%- mcpServerClassName %> MCP server. */
export class <%- mcpServerClassName %>ClientLangChain {
  static async create(): Promise<StructuredToolInterface[]> {
    if (process.env.SERVE_LOCAL === 'true') {
      return AgentCoreMcpClientLangChain.withoutAuth({
        url: 'http://localhost:<%- mcpServerPort %>/mcp',
      });
    }
    const config = await getAgentCoreRuntimeConfig();
    const agentRuntimeArn = config.agentRuntimes?.['<%- mcpServerClassName %>'];
    if (!agentRuntimeArn) {
      throw new Error(
        `No connected MCP server runtime named '<%- mcpServerClassName %>' found in runtime configuration.`,
      );
    }
    return AgentCoreMcpClientLangChain.withIamAuth({ agentRuntimeArn });
  }
}
