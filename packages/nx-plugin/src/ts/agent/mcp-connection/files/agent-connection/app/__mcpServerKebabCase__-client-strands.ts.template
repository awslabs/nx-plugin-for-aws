import { McpClient } from '@strands-agents/sdk';
import { AgentCoreMcpClientStrands } from '../core/agentcore-mcp-client-strands<% if (esm) { %>.js<% } %>';
import { getAgentCoreRuntimeConfig } from '../core/runtime-config<% if (esm) { %>.js<% } %>';

/** Strands client for the <%- mcpServerClassName %> MCP server. */
export class <%- mcpServerClassName %>ClientStrands {
  static async create(): Promise<McpClient> {
    if (process.env.LOCAL_DEV === 'true') {
      return AgentCoreMcpClientStrands.withoutAuth({
        url: 'http://localhost:<%- mcpServerPort %>/mcp',
      });
    }
    const config = await getAgentCoreRuntimeConfig();
    const agentRuntimeArn = config.agentRuntimes?.['<%- mcpServerClassName %>'];
    if (!agentRuntimeArn) {
      throw new Error(
        `No connected MCP server runtime named '<%- mcpServerClassName %>' found in runtime configuration.`,
      );
    }
    return AgentCoreMcpClientStrands.withIamAuth({ agentRuntimeArn });
  }
}
