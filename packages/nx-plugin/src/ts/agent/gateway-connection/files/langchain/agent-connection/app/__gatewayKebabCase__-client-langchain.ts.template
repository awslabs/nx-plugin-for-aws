import type { StructuredToolInterface } from '@langchain/core/tools';
import { AgentCoreGatewayMcpClientLangChain } from '../core/agentcore-gateway-mcp-client-langchain.js';
import { getAgentCoreRuntimeConfig } from '../core/runtime-config.js';

/**
 * LangChain client for the <%- gatewayClassName %> AgentCore Gateway.
 *
 * Deployed: SigV4-signed tools pointing at the gateway URL. Local
 * (`SERVE_LOCAL=true`): plain-HTTP tools pointing at the local gateway started
 * by the gateway project's serve-local target. The local gateway aggregates
 * every attached MCP server but does not evaluate Cedar policies.
 */
export class <%- gatewayClassName %>ClientLangChain {
  static async create(): Promise<StructuredToolInterface[]> {
    if (process.env.SERVE_LOCAL === 'true') {
      return AgentCoreGatewayMcpClientLangChain.withoutAuth({
        gatewayUrl: 'http://localhost:<%- gatewayPort %>/mcp',
      });
    }
    const config = await getAgentCoreRuntimeConfig();
    const gatewayUrl = config.gateways?.['<%- gatewayClassName %>'];
    if (!gatewayUrl) {
      throw new Error(
        `No connected gateway named '<%- gatewayClassName %>' found in runtime configuration.`,
      );
    }
    return AgentCoreGatewayMcpClientLangChain.withIamAuth({ gatewayUrl });
  }
}
