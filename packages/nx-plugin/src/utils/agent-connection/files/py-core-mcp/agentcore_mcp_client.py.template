from collections.abc import Callable

import boto3
import httpx
from mcp.client.streamable_http import streamablehttp_client
from strands.tools.mcp.mcp_client import MCPClient

from .auth import SigV4HTTPXAuth


class AgentCoreMCPClient:
    """Factory for clients to call MCP servers hosted on Bedrock AgentCore Runtime.

    The ``session_id_provider`` callable is invoked lazily each time the
    underlying transport is opened, so callers can supply a value that is
    only populated once the first inbound request has arrived on the
    enclosing agent's container.
    """

    @staticmethod
    def _build_url(agent_runtime_arn: str) -> tuple[str, str]:
        """Extract region from ARN and construct the invocation URL.

        ARN format: arn:partition:service:region:account-id:resource
        """
        region = agent_runtime_arn.split(":")[3]
        encoded_arn = agent_runtime_arn.replace(":", "%3A").replace("/", "%2F")
        url = f"https://bedrock-agentcore.{region}.amazonaws.com/runtimes/{encoded_arn}/invocations?qualifier=DEFAULT"
        return region, url

    @staticmethod
    def _create(
        agent_runtime_arn: str,
        session_id_provider: Callable[[], str],
        extra_headers_provider: Callable[[], dict] | None = None,
        auth_handler: httpx.Auth | None = None,
    ) -> MCPClient:
        _, url = AgentCoreMCPClient._build_url(agent_runtime_arn)

        def _open_transport():
            headers = {
                "X-Amzn-Bedrock-AgentCore-Runtime-Session-Id": session_id_provider(),
            }
            if extra_headers_provider is not None:
                headers.update(extra_headers_provider())
            return streamablehttp_client(
                url,
                auth=auth_handler,
                timeout=120,
                terminate_on_close=False,
                headers=headers,
            )

        return MCPClient(_open_transport)

    @staticmethod
    def with_iam_auth(
        agent_runtime_arn: str,
        session_id_provider: Callable[[], str],
    ) -> MCPClient:
        """Create an MCP client with IAM (SigV4) authentication.

        Region and credentials are derived automatically from the ARN
        and the default credential provider chain.
        """
        region, _ = AgentCoreMCPClient._build_url(agent_runtime_arn)
        boto_session = boto3.Session(region_name=region)
        credentials = boto_session.get_credentials()
        return AgentCoreMCPClient._create(
            agent_runtime_arn=agent_runtime_arn,
            session_id_provider=session_id_provider,
            auth_handler=SigV4HTTPXAuth(credentials, "bedrock-agentcore", region),
        )

    @staticmethod
    def with_jwt_auth(
        agent_runtime_arn: str,
        access_token_provider: Callable[[], str],
        session_id_provider: Callable[[], str],
    ) -> MCPClient:
        """Create an MCP client with JWT authentication.

        Args:
            agent_runtime_arn: The ARN of the AgentCore runtime.
            access_token_provider: A callable that returns the JWT access token.
            session_id_provider: A callable that returns the session id to
                forward on outbound calls.
        """
        return AgentCoreMCPClient._create(
            agent_runtime_arn=agent_runtime_arn,
            session_id_provider=session_id_provider,
            extra_headers_provider=lambda: {
                "Authorization": f"Bearer {access_token_provider()}",
            },
        )
