import * as readline from 'node:readline/promises';

/**
 * Parse a CLI argument value, eg --accessToken xxx
 */
export const getCliArg = (name: string): string | undefined => {
  const prefix = `--${name}`;
  const idx = process.argv.indexOf(prefix);
  if (idx !== -1 && idx + 1 < process.argv.length) {
    return process.argv[idx + 1];
  }
  return undefined;
};

/**
 * Run an interactive CLI chat loop. The caller's `onMessage` callback is
 * invoked for each user message — it should write streamed response chunks
 * to `process.stdout` and return (or resolve) when the response is complete.
 */
export const runCliChat = async (
  onMessage: (message: string) => Promise<void>,
): Promise<void> => {
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
  });

  console.log('Chat with your agent (type "/exit" or "/quit" to quit)');

  // eslint-disable-next-line no-constant-condition
  while (true) {
    const message = await rl.question('\nYou: ');
    if (!message.trim()) continue;
    if (message.trim() === '/exit' || message.trim() === '/quit') break;

    process.stdout.write('\nAgent: ');
    await onMessage(message);
    process.stdout.write('\n');
  }

  rl.close();
  process.exit(0);
};
