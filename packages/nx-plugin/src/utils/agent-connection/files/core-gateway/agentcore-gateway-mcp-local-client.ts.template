import { McpClient } from '@strands-agents/sdk';
import { StreamableHTTPClientTransport } from '@modelcontextprotocol/sdk/client/streamableHttp.js';
import type {
  Transport,
  TransportSendOptions,
} from '@modelcontextprotocol/sdk/shared/transport.js';
import type {
  JSONRPCMessage,
  MessageExtraInfo,
} from '@modelcontextprotocol/sdk/types.js';
import { getCurrentSessionId } from './session-context.js';

const SESSION_HEADER = 'X-Amzn-Bedrock-AgentCore-Runtime-Session-Id';

/**
 * Separator used by AgentCore Gateway when prefixing tool names from a
 * target. Local mode mirrors this so that agents see the same tool names
 * locally and deployed.
 */
const PREFIX_SEPARATOR = '___';

/**
 * Describes one MCP server attached to a gateway, for local development use.
 * The `name` matches the gateway target name that production will use, and
 * is also used as the local tool-name prefix so agents see identical tool
 * names whether running locally or against the deployed gateway.
 */
export interface LocalMcpServerBinding {
  name: string;
  localUrl: string;
}

/**
 * A `Transport` proxy that mirrors the deployed gateway's tool-name
 * prefixing for one MCP server target. Tool names appear to the agent as
 * `<target>___<tool>` in `tools/list` responses, and the prefix is stripped
 * from outgoing `tools/call` requests before they reach the upstream MCP
 * server.
 *
 * Wrapping the transport (rather than subclassing `McpClient` or `McpTool`)
 * keeps the rewrite invisible to Strands' tool registry — the agent's
 * registered tool names are namespaced and never collide across multiple
 * MCP servers, even when the same server is attached to multiple gateways.
 */
class PrefixingTransport implements Transport {
  private readonly _prefix: string;
  private readonly _inner: Transport;

  public sessionId?: string;
  public onmessage?: <T extends JSONRPCMessage>(
    message: T,
    extra?: MessageExtraInfo,
  ) => void;
  public onerror?: (error: Error) => void;
  public onclose?: () => void;

  constructor(inner: Transport, targetName: string) {
    this._inner = inner;
    this._prefix = `${targetName}${PREFIX_SEPARATOR}`;

    inner.onmessage = (msg, extra) => {
      this.onmessage?.(this._rewriteIncoming(msg), extra);
    };
    inner.onerror = (err) => this.onerror?.(err);
    inner.onclose = () => this.onclose?.();
  }

  async start(): Promise<void> {
    await this._inner.start();
    this.sessionId = this._inner.sessionId;
  }

  async send(
    message: JSONRPCMessage,
    options?: TransportSendOptions,
  ): Promise<void> {
    return this._inner.send(this._rewriteOutgoing(message), options);
  }

  async close(): Promise<void> {
    return this._inner.close();
  }

  /** Strip the prefix from outgoing `tools/call` requests. */
  private _rewriteOutgoing(message: JSONRPCMessage): JSONRPCMessage {
    const m = message as unknown as {
      method?: string;
      params?: { name?: unknown; [k: string]: unknown };
    };
    if (m.method === 'tools/call' && m.params) {
      const name = m.params.name;
      if (typeof name === 'string' && name.startsWith(this._prefix)) {
        const rewritten = {
          ...message,
          params: { ...m.params, name: name.slice(this._prefix.length) },
        };
        return rewritten as unknown as JSONRPCMessage;
      }
    }
    return message;
  }

  /** Add the prefix to tool names in incoming `tools/list` responses. */
  private _rewriteIncoming<T extends JSONRPCMessage>(message: T): T {
    const m = message as unknown as {
      result?: { tools?: Array<{ name?: string }> };
    };
    if (m.result?.tools && Array.isArray(m.result.tools)) {
      const rewritten = {
        ...message,
        result: {
          ...m.result,
          tools: m.result.tools.map((t) =>
            t.name ? { ...t, name: `${this._prefix}${t.name}` } : t,
          ),
        },
      };
      return rewritten as unknown as T;
    }
    return message;
  }
}

/**
 * Factory for gateway-like MCP access during local development.
 *
 * Returns an array of `McpClient` instances, one per attached MCP server.
 * Strands' `Agent` accepts nested tool arrays, so the array can be spread
 * directly into `tools: [...]` — the agent aggregates tools from every
 * backing client transparently.
 *
 * Each underlying client:
 * - forwards the current async-context session via the
 *   `X-Amzn-Bedrock-AgentCore-Runtime-Session-Id` header
 * - exposes tools as `<target>___<tool>` to match the deployed gateway's
 *   tool-name prefixing (so agents see identical tool names locally and
 *   deployed, and the same MCP server can be attached to multiple gateways
 *   without name collisions in the agent's tool registry)
 *
 * Remaining fidelity gaps vs the real gateway:
 * - No Cedar policy evaluation
 * - No semantic tool search
 *
 * Use `GATEWAY_URL_OVERRIDE` with a deployed gateway to test those behaviors.
 */
export class AgentCoreGatewayMcpLocalMultiplexClient {
  static create(servers: LocalMcpServerBinding[]): McpClient[] {
    return servers.map((s) => {
      const fetchWithSession: typeof fetch = async (input, init) => {
        const headers = new Headers(init?.headers);
        const sessionId = getCurrentSessionId();
        if (sessionId) headers.set(SESSION_HEADER, sessionId);
        return fetch(input, { ...init, headers });
      };
      const innerTransport = new StreamableHTTPClientTransport(
        new URL(s.localUrl),
        { fetch: fetchWithSession },
      );
      const transport = new PrefixingTransport(innerTransport, s.name);
      return new McpClient({ transport });
    });
  }
}
