import { AsyncLocalStorage } from 'node:async_hooks';

const sessionStorage = new AsyncLocalStorage<string>();

/**
 * Run `callback` with `sessionId` as the current session for the duration of
 * the async operation. Anything in the async scope of `callback` — including
 * downstream MCP/A2A client calls — can read the session via
 * {@link getCurrentSessionId}.
 */
export const runWithSessionId = <T>(
  sessionId: string,
  callback: () => T,
): T => {
  return sessionStorage.run(sessionId, callback);
};

/**
 * Return the session ID for the current async scope, or `undefined` if none
 * has been set. AgentCore runtime sessions propagate via the
 * `X-Amzn-Bedrock-AgentCore-Runtime-Session-Id` header, which the server
 * entrypoint reads and stores here so downstream clients can forward it.
 */
export const getCurrentSessionId = (): string | undefined => {
  return sessionStorage.getStore();
};
