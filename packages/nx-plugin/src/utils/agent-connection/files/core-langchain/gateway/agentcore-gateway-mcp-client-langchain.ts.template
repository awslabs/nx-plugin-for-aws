import { Client } from '@modelcontextprotocol/sdk/client/index.js';
import { loadMcpTools } from '@langchain/mcp-adapters';
import type { StructuredToolInterface } from '@langchain/core/tools';
import {
  AgentCoreGatewayMcpTransport,
  type AgentCoreGatewayMcpTransportIamOptions,
} from './agentcore-gateway-mcp-transport.js';

/**
 * Loads LangChain tools from an AgentCore Gateway.
 *
 * Reuses the Layer-1 {@link AgentCoreGatewayMcpTransport} (which bakes in the
 * Layer-0 session-forwarding SigV4 / plain fetch); it re-implements neither
 * auth nor region derivation. A gateway is reached by URL (it has no ARN), so
 * the region is parsed from the gateway URL unless given explicitly. As with the
 * MCP client, `@langchain/mcp-adapters`' `MultiServerMCPClient` config cannot
 * take a custom fetch or a pre-built transport, so this builds the transport,
 * hands it to a raw MCP SDK `Client`, connects, and wraps the live client's tools
 * via `loadMcpTools`. The Layer-0 SigV4 auth forwards the current session via the
 * AgentCore session header, which the gateway propagates to downstream targets.
 *
 * Connection lifetime: the returned tools are bound to the LIVE `Client`, which
 * stays connected for the agent's lifetime and is deliberately NOT closed after
 * loading (closing it would leave every tool dead-on-arrival).
 */
export class AgentCoreGatewayMcpClientLangChain {
  /** SigV4-authenticated tools for an AgentCore Gateway. */
  static withIamAuth(
    options: AgentCoreGatewayMcpTransportIamOptions,
  ): Promise<StructuredToolInterface[]> {
    return loadTools(AgentCoreGatewayMcpTransport.withIamAuth(options));
  }

  /** Plain-HTTP tools, for the local gateway started by serve-local. */
  static withoutAuth(options: {
    gatewayUrl: string;
  }): Promise<StructuredToolInterface[]> {
    return loadTools(AgentCoreGatewayMcpTransport.withoutAuth(options));
  }
}

const loadTools = async (
  transport: Awaited<
    ReturnType<typeof AgentCoreGatewayMcpTransport.withIamAuth>
  >,
): Promise<StructuredToolInterface[]> => {
  const client = new Client({
    name: 'agentcore-gateway-mcp-client',
    version: '1.0.0',
  });
  // Keep the connection alive for the agent's lifetime: do NOT close it here.
  // Each tool invocation reuses this client, so closing it would make every tool
  // fail on a dead connection.
  await client.connect(transport);
  return loadMcpTools('server', client);
};
