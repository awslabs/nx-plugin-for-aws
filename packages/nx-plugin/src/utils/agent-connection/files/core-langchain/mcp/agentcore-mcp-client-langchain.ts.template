import { Client } from '@modelcontextprotocol/sdk/client/index.js';
import { loadMcpTools } from '@langchain/mcp-adapters';
import type { StructuredToolInterface } from '@langchain/core/tools';
import {
  AgentCoreMcpTransport,
  type AgentCoreMcpTransportIamOptions,
  type AgentCoreMcpTransportJwtOptions,
  type AgentCoreMcpTransportNoAuthOptions,
} from './agentcore-mcp-transport.js';

/**
 * Loads LangChain tools from an MCP server on an AgentCore runtime.
 *
 * Reuses the Layer-1 {@link AgentCoreMcpTransport} (which bakes in the Layer-0
 * session-forwarding SigV4 / JWT / plain fetch); it re-implements neither auth
 * nor URL derivation. `@langchain/mcp-adapters`' `MultiServerMCPClient` config
 * cannot take a custom fetch or a pre-built transport, so this modestly bypasses
 * it: it builds the transport, hands it to a raw MCP SDK `Client`, connects, and
 * uses the exported `loadMcpTools` helper to wrap the live client's tools as
 * LangChain `StructuredTool`s.
 *
 * Connection lifetime: the returned tools are bound to the LIVE `Client`, which
 * stays connected for the agent's lifetime. The client is deliberately NOT
 * closed after loading: every tool invocation reuses this open session, so
 * closing it here would leave every tool dead-on-arrival. The unhandled-rejection
 * guard on `connect()` keeps a transient connection blip from crashing the
 * process at construction time.
 */
export class AgentCoreMcpClientLangChain {
  /** SigV4-authenticated tools for a Bedrock AgentCore runtime. */
  static withIamAuth(
    options: AgentCoreMcpTransportIamOptions,
  ): Promise<StructuredToolInterface[]> {
    return loadTools(AgentCoreMcpTransport.withIamAuth(options));
  }

  /** Bearer-authenticated tools for a Bedrock AgentCore runtime. */
  static withJwtAuth(
    options: AgentCoreMcpTransportJwtOptions,
  ): Promise<StructuredToolInterface[]> {
    return loadTools(AgentCoreMcpTransport.withJwtAuth(options));
  }

  /** Plain-HTTP tools, for local dev. */
  static withoutAuth(
    options: AgentCoreMcpTransportNoAuthOptions,
  ): Promise<StructuredToolInterface[]> {
    return loadTools(AgentCoreMcpTransport.withoutAuth(options));
  }
}

const loadTools = async (
  transport: Awaited<ReturnType<typeof AgentCoreMcpTransport.withIamAuth>>,
): Promise<StructuredToolInterface[]> => {
  const client = new Client({ name: 'agentcore-mcp-client', version: '1.0.0' });
  // Keep the connection alive for the agent's lifetime: do NOT close it here.
  // The returned tools open no new session of their own; each invocation reuses
  // this client, so closing it would make every tool fail on a dead connection.
  await client.connect(transport);
  return loadMcpTools('server', client);
};
