import uuid
from collections.abc import Callable
from urllib.parse import quote

import boto3
import httpx
from a2a.client import ClientConfig
from strands.agent.a2a_agent import A2AAgent

from .auth import SigV4HTTPXAuth
from .session_context import get_current_session_id

SESSION_ID_HEADER = "X-Amzn-Bedrock-AgentCore-Runtime-Session-Id"


class _SessionHeaderAuth(httpx.Auth):
    """httpx Auth that stamps the AgentCore session header per-request.

    Resolves the session ID from the current async context on each request so
    A2A clients created at startup still forward the caller's session. Falls
    back to *default_session_id* when no context is set. Chains to *inner*
    (e.g. SigV4) so both the session header and the underlying auth are
    applied.
    """

    requires_request_body = True
    requires_response_body = True

    def __init__(self, default_session_id: str, inner: httpx.Auth | None):
        self._default_session_id = default_session_id
        self._inner = inner

    def auth_flow(self, request: httpx.Request):  # type: ignore[override]
        session_id = get_current_session_id() or self._default_session_id
        request.headers[SESSION_ID_HEADER] = session_id
        if self._inner is None:
            yield request
            return
        yield from self._inner.auth_flow(request)


class AgentCoreA2aClient:
    """Factory for clients to call A2A agents hosted on Bedrock AgentCore Runtime."""

    @staticmethod
    def _build_url(agent_runtime_arn: str) -> tuple[str, str]:
        """Extract region from ARN and construct the A2A invocations URL.

        ARN format: arn:partition:service:region:account-id:resource
        A2A on AgentCore is mounted at `/invocations/` (trailing slash matters).
        """
        region = agent_runtime_arn.split(":")[3]
        encoded_arn = quote(agent_runtime_arn, safe="")
        url = f"https://bedrock-agentcore.{region}.amazonaws.com/runtimes/{encoded_arn}/invocations/"
        return region, url

    @staticmethod
    def _build(
        url: str,
        auth: httpx.Auth | None,
        headers: dict | None,
        session_id: str | None,
        *,
        name: str | None,
        description: str | None,
    ) -> A2AAgent:
        # Generated once when no session is supplied by either the caller or
        # the current async context, so repeated requests from outside a
        # server handler share one session rather than creating a new session
        # per call.
        default_session_id = session_id or str(uuid.uuid4())
        session_auth = _SessionHeaderAuth(default_session_id, auth)
        httpx_client = httpx.AsyncClient(
            auth=session_auth,
            headers=headers or {},
            timeout=120,
        )
        client_config = ClientConfig(httpx_client=httpx_client, streaming=False)
        kwargs: dict = {"endpoint": url, "client_config": client_config}
        if name:
            kwargs["name"] = name
        if description:
            kwargs["description"] = description
        return A2AAgent(**kwargs)

    @staticmethod
    def with_iam_auth(
        agent_runtime_arn: str,
        *,
        name: str | None = None,
        description: str | None = None,
        session_id: str | None = None,
    ) -> A2AAgent:
        """Create an `A2AAgent` with IAM (SigV4) authentication."""
        region, url = AgentCoreA2aClient._build_url(agent_runtime_arn)
        credentials = boto3.Session(region_name=region).get_credentials()
        return AgentCoreA2aClient._build(
            url,
            SigV4HTTPXAuth(credentials, "bedrock-agentcore", region),
            None,
            session_id,
            name=name,
            description=description,
        )

    @staticmethod
    def with_jwt_auth(
        agent_runtime_arn: str,
        access_token_provider: Callable[[], str],
        *,
        name: str | None = None,
        description: str | None = None,
        session_id: str | None = None,
    ) -> A2AAgent:
        """Create an `A2AAgent` with JWT Bearer authentication."""
        _, url = AgentCoreA2aClient._build_url(agent_runtime_arn)
        headers = {"Authorization": f"Bearer {access_token_provider()}"}
        return AgentCoreA2aClient._build(
            url,
            None,
            headers,
            session_id,
            name=name,
            description=description,
        )
