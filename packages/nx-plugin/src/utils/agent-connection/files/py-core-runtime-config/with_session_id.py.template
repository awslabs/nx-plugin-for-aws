"""Route each agent call to a per-session Agent.

Strands' Python ``MCPClient`` runs its HTTP transport in a long-lived task
whose ``contextvars`` are snapshotted when the client opens. That means a
session set on an inbound request does not reach MCP calls issued by an
Agent that was constructed before the request arrived. ``with_session_id``
works around this by lazily constructing a fresh Agent the first time each
session is seen, so its MCP clients inherit the right session from the start.
"""

from collections.abc import Callable, Iterator
from contextlib import AbstractContextManager, ExitStack, contextmanager
from typing import Any

from .session_context import get_current_session_id


@contextmanager
def with_session_id(
    agent_factory: Callable[[], AbstractContextManager[Any]],
    *,
    name: str,
    description: str,
) -> Iterator[Any]:
    """Wrap an agent factory so each session gets its own cached Agent.

    The returned proxy looks like an Agent (``stream_async`` / ``invoke_async``,
    ``name``, ``description``, ``cancel``) but routes every call to a per-session
    instance constructed on first use. Nothing is built until a request arrives,
    so importing the module is side-effect-free.
    """
    stack = ExitStack()
    agents: dict[str, Any] = {}

    def _for_session() -> Any:
        sid = get_current_session_id() or "default"
        if sid not in agents:
            agents[sid] = stack.enter_context(agent_factory())
        return agents[sid]

    class _SessionRoutingAgent:
        @property
        def name(self) -> str:
            return name

        @property
        def description(self) -> str:
            return description

        def __getattr__(self, attr: str) -> Any:
            # Fall-through for any other agent attribute (tool_registry,
            # model, hooks, etc.) — resolved against the current session's
            # agent so downstream frameworks that introspect the agent still
            # see consistent state.
            return getattr(_for_session(), attr)

        def stream_async(self, *args, **kwargs):
            return _for_session().stream_async(*args, **kwargs)

        def invoke_async(self, *args, **kwargs):
            return _for_session().invoke_async(*args, **kwargs)

        def cancel(self) -> None:
            for agent in agents.values():
                agent.cancel()

    try:
        yield _SessionRoutingAgent()
    finally:
        stack.close()
