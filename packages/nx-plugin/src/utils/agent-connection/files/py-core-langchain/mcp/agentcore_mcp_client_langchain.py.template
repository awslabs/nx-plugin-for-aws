import asyncio
from collections.abc import Callable
from concurrent.futures import ThreadPoolExecutor

import boto3
import httpx

from langchain_core.tools import BaseTool
from langchain_mcp_adapters.client import MultiServerMCPClient

from .agentcore_endpoints import mcp_url_from_arn, region_from_arn
from .auth.session import jwt_auth, plain_auth, sigv4_auth


def _run_sync(coro):
    """Run a coroutine to completion from sync code, even when an event loop is
    already running on this thread (e.g. tools are loaded at agent-construction
    time, which under uvicorn happens inside the running loop). asyncio.run()
    refuses a running loop, so fall back to a dedicated loop on a worker thread.
    """
    try:
        asyncio.get_running_loop()
    except RuntimeError:
        return asyncio.run(coro)
    with ThreadPoolExecutor(max_workers=1) as pool:
        return pool.submit(asyncio.run, coro).result()


def _load_tools(url: str, auth: httpx.Auth) -> list[BaseTool]:
    # Hand langchain-mcp-adapters a CONNECTION CONFIG (not a live session), so it
    # owns the session lifetime: get_tools() lists the server's tools once now
    # (over a throwaway session), and every returned BaseTool keeps this config
    # and opens a FRESH ClientSession on each invocation. The tools therefore
    # survive past construction — there is no shared session to close. This is
    # why the client passes the Layer-0 httpx.Auth straight through rather than
    # entering the Layer-1 transport context (which would close on block exit).
    client = MultiServerMCPClient(
        {
            "server": {
                "transport": "streamable_http",
                "url": url,
                "auth": auth,
                "terminate_on_close": False,
            }
        }
    )
    return _run_sync(client.get_tools())


class AgentCoreMCPClientLangChain:
    """Loads LangChain tools from an MCP server on an AgentCore runtime.

    Reuses the Layer-0 session-forwarding auth builders (``sigv4_auth`` /
    ``jwt_auth`` / ``plain_auth``) and the framework-agnostic endpoint resolver
    (``mcp_url_from_arn`` / ``region_from_arn``) — it re-implements neither auth
    nor URL derivation. Unlike the Strands Layer-2 client it does NOT enter the
    Layer-1 transport context; langchain-mcp-adapters owns the session lifetime
    so each tool opens a fresh session per call.
    """

    @staticmethod
    def with_iam_auth(agent_runtime_arn: str) -> list[BaseTool]:
        """SigV4-authenticated tools for a Bedrock AgentCore runtime."""
        region = region_from_arn(agent_runtime_arn)
        url = mcp_url_from_arn(agent_runtime_arn)
        credentials = boto3.Session(region_name=region).get_credentials()
        return _load_tools(url, sigv4_auth(credentials, region))

    @staticmethod
    def with_jwt_auth(
        agent_runtime_arn: str, access_token_provider: Callable[[], str]
    ) -> list[BaseTool]:
        """Bearer-authenticated tools for a Bedrock AgentCore runtime."""
        url = mcp_url_from_arn(agent_runtime_arn)
        return _load_tools(url, jwt_auth(access_token_provider))

    @staticmethod
    def without_auth(url: str) -> list[BaseTool]:
        """Plain-HTTP tools — for local dev."""
        return _load_tools(url, plain_auth())
