terraform {
  required_version = ">= 1.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.23"
    }
    awscc = {
      source  = "hashicorp/awscc"
      version = ">= 1.52"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.0"
    }
  }
}
