import { Fn, Lazy, Names, Stack, Token } from 'aws-cdk-lib';
import { Construct } from 'constructs';
import * as fs from 'node:fs';
import * as path from 'node:path';
import * as url from 'node:url';
import {
  Gateway,
  GatewayAuthorizer,
  McpGatewaySearchType,
  McpProtocolConfiguration,
  MCPProtocolVersion,
  PolicyEngine,
  PolicyEngineMode,
  PolicyValidationMode,
} from '@aws-cdk/aws-bedrock-agentcore-alpha';
import { CfnGatewayTarget, Runtime } from 'aws-cdk-lib/aws-bedrockagentcore';
import { IGrantable, IPrincipal, PolicyStatement } from 'aws-cdk-lib/aws-iam';
import { RuntimeConfig } from '../../../core/runtime-config.js';
import { findWorkspaceRoot } from '../../../core/workspace.js';

/**
 * An MCP server construct that can be registered as a Gateway target.
 * Constructs generated by `ts#mcp-server` and `py#mcp-server` satisfy this.
 */
export interface IMcpServerConstruct extends Construct {
  readonly agentCoreRuntime: Runtime;
}

/**
 * Props for the <%- nameClassName %> construct. None required — the gateway
 * is fully configured by the generator. Additional props may be added in
 * future (e.g. custom KMS key) as non-breaking additions.
 */
export type <%- nameClassName %>Props = Record<string, never>;

/**
 * AgentCore Gateway wired for MCP protocol with IAM inbound auth.
 *
 * Cedar policies are loaded from the gateway project's policies/ directory
 * at synth time and attached to a PolicyEngine running in ENFORCE mode.
 */
export class <%- nameClassName %> extends Construct implements IGrantable {
  public readonly gateway: Gateway;
  public readonly policyEngine: PolicyEngine;

  constructor(scope: Construct, id: string, _props?: <%- nameClassName %>Props) {
    super(scope, id);

    const rc = RuntimeConfig.ensure(this);

    this.policyEngine = new PolicyEngine(this, 'PolicyEngine', {
      policyEngineName: Lazy.string({
        produce: () =>
          Names.uniqueResourceName(this.policyEngine, { maxLength: 48 }),
      }),
      description: 'Cedar policy engine for <%- nameClassName %>',
    });

    this.gateway = new Gateway(this, 'Gateway', {
      gatewayName: Lazy.string({
        produce: () =>
          Names.uniqueResourceName(this.gateway, { maxLength: 40 }),
      }),
      protocolConfiguration: new McpProtocolConfiguration({
        searchType: McpGatewaySearchType.SEMANTIC,
        supportedVersions: [MCPProtocolVersion.MCP_2025_03_26],
      }),
      authorizerConfiguration: GatewayAuthorizer.usingAwsIam(),
      policyEngineConfiguration: {
        policyEngine: this.policyEngine,
        mode: PolicyEngineMode.ENFORCE,
      },
    });

    // Load every .cedar file under <%- projectDirectory %>/policies/ and
    // attach as a Policy to the PolicyEngine. Substitute ${gateway_arn} and
    // ${account_id} at synth time using a Lazy string (both are CDK tokens).
    const policiesDir = path.join(
      findWorkspaceRoot(url.fileURLToPath(new URL(import.meta.url))),
      '<%- projectDirectory %>/policies',
    );
    if (fs.existsSync(policiesDir)) {
      for (const file of fs.readdirSync(policiesDir)) {
        if (!file.endsWith('.cedar')) continue;
        const raw = fs.readFileSync(path.join(policiesDir, file), 'utf-8');
        const definition = Lazy.string({
          produce: () =>
            raw
              .replace(
                /\$\{gateway_arn\}/g,
                Token.asString(this.gateway.gatewayArn),
              )
              .replace(
                /\$\{account_id\}/g,
                Token.asString(Stack.of(this).account),
              ),
        });
        const policyId = toPascalCase(file.replace(/\.cedar$/, ''));
        this.policyEngine.addPolicy(policyId, {
          definition,
          description: `Policy loaded from ${file}`,
          validationMode: PolicyValidationMode.IGNORE_ALL_FINDINGS,
        });
      }
    }

    // Workaround: the alpha L2 grants AuthorizeAction /
    // PartiallyAuthorizeActions but not CheckAuthorizePermissions, which
    // the CFN handler's readiness probe requires during gateway creation.
    // Remove once fixed upstream in @aws-cdk/aws-bedrock-agentcore-alpha.
    this.gateway.role.addToPrincipalPolicy(
      new PolicyStatement({
        actions: ['bedrock-agentcore:CheckAuthorizePermissions'],
        resources: ['*'],
      }),
    );

    rc.set('agentcore', 'gateways', {
      ...rc.get('agentcore').gateways,
      <%- nameClassName %>: this.gateway.gatewayUrl,
    });
  }

  /**
   * The principal to grant permissions to.
   */
  public get grantPrincipal(): IPrincipal {
    return this.gateway.role.grantPrincipal;
  }

  /**
   * Grants an IAM principal permission to invoke this gateway.
   */
  public grantInvokeAccess(grantee: IGrantable) {
    this.gateway.grantInvoke(grantee);
  }

  /**
   * Add an MCP server construct as a target of this Gateway.
   *
   * The target name defaults to the construct's `node.id` in kebab-case
   * (e.g. `MyMcpServer` -> `my-mcp-server`). It prefixes Cedar action names
   * (`AgentCore::Action::"<targetName>___<toolName>"`), so renaming it later
   * invalidates policies that reference the old name.
   */
  public addMcpServer(
    server: IMcpServerConstruct,
    props?: {
      gatewayTargetName?: string;
    },
  ): CfnGatewayTarget {
    return this.addMcpServerTarget(`${server.node.id}Target`, {
      gatewayTargetName: props?.gatewayTargetName ?? toKebabCase(server.node.id),
      mcpServerRuntimeArn: server.agentCoreRuntime.agentRuntimeArn,
    });
  }

  /**
   * Register an MCP server runtime ARN as a Gateway target. Prefer
   * {@link addMcpServer} when the construct is in scope.
   */
  public addMcpServerTarget(
    id: string,
    props: {
      gatewayTargetName: string;
      mcpServerRuntimeArn: string;
    },
  ): CfnGatewayTarget {
    const region = Stack.of(this).region;
    // The endpoint must URL-encode the runtime ARN (':' -> '%3A', '/' -> '%2F').
    // The ARN is a CDK token, so encode at deploy time via Fn.join/Fn.split.
    const arn = props.mcpServerRuntimeArn;
    const encodedArn = Fn.join(
      '%2F',
      Fn.split('/', Fn.join('%3A', Fn.split(':', arn))),
    );
    const endpoint = `https://bedrock-agentcore.${region}.amazonaws.com/runtimes/${encodedArn}/invocations?qualifier=DEFAULT`;
    const target = new CfnGatewayTarget(this, id, {
      gatewayIdentifier: this.gateway.gatewayId,
      name: props.gatewayTargetName,
      targetConfiguration: {
        mcp: {
          mcpServer: {
            endpoint,
          },
        },
      },
      credentialProviderConfigurations: [
        {
          credentialProviderType: 'GATEWAY_IAM_ROLE',
          credentialProvider: {
            iamCredentialProvider: {
              service: 'bedrock-agentcore',
            },
          },
        },
      ],
    });

    // Grant the gateway role invoke access to the target runtime before the
    // target is created — AgentCore probes the target during creation, which
    // stalls if the permission is not yet in place.
    const grant = this.gateway.role.addToPrincipalPolicy(
      new PolicyStatement({
        actions: [
          'bedrock-agentcore:InvokeAgentRuntime',
          'bedrock-agentcore:InvokeAgentRuntimeWithWebSocketStream',
        ],
        resources: [
          props.mcpServerRuntimeArn,
          `${props.mcpServerRuntimeArn}/*`,
        ],
      }),
    );
    if (grant.policyDependable) {
      target.node.addDependency(grant.policyDependable);
    }

    return target;
  }
}

const toPascalCase = (s: string): string =>
  s
    .split(/[-_\s]+/)
    .filter(Boolean)
    .map((w) => w[0].toUpperCase() + w.slice(1).toLowerCase())
    .join('');

const toKebabCase = (s: string): string =>
  s
    // Insert `-` before any uppercase letter that follows a lowercase or digit
    // (handles `MyMcpServer` -> `My-Mcp-Server`).
    .replace(/([a-z0-9])([A-Z])/g, '$1-$2')
    // Insert `-` between consecutive uppercase letters where the next char is
    // lowercase (handles `MCPServer` -> `MCP-Server` -> `mcp-server`).
    .replace(/([A-Z])([A-Z][a-z])/g, '$1-$2')
    .toLowerCase()
    .replace(/[_\s]+/g, '-');
