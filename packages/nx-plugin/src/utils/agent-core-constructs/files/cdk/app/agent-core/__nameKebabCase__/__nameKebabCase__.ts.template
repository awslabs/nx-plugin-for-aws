import { Lazy, Names } from 'aws-cdk-lib';
import { Platform } from 'aws-cdk-lib/aws-ecr-assets';
import { Construct } from 'constructs';
import { execSync } from 'child_process';
import * as path from 'path';
import * as url from 'url';
import {
  AgentRuntimeArtifact,
  ProtocolType,
  Runtime,
  RuntimeProps,
<%_ if (auth === 'Cognito') { _%>
  RuntimeAuthorizerConfiguration,
<%_ } _%>
} from '@aws-cdk/aws-bedrock-agentcore-alpha';
import { IGrantable, IPrincipal<%_ if (auth === 'IAM') { _%>, Grant<%_ } _%> } from 'aws-cdk-lib/aws-iam';
<%_ if (auth === 'Cognito') { _%>
import { IUserPool, IUserPoolClient } from 'aws-cdk-lib/aws-cognito';
<%_ } _%>
import { RuntimeConfig } from '../../../core/runtime-config.js';

<%_ if (auth === 'IAM') { _%>
export type <%- nameClassName %>Props = Omit<
  RuntimeProps,
  | 'runtimeName'
  | 'protocolConfiguration'
  | 'agentRuntimeArtifact'
  | 'authorizerConfiguration'
>;
<%_ } else if (auth === 'Cognito') { _%>
export type <%- nameClassName %>Props = Omit<
  RuntimeProps,
  | 'runtimeName'
  | 'protocolConfiguration'
  | 'agentRuntimeArtifact'
  | 'authorizerConfiguration'
> & {
  /**
   * Identity details for Cognito Authentication
   */
  identity: {
    userPool: IUserPool;
    userPoolClient: IUserPoolClient;
  };
};
<%_ } _%>

export class <%- nameClassName %> extends Construct implements IGrantable {
  public readonly dockerImage: AgentRuntimeArtifact;
  public readonly agentCoreRuntime: Runtime;

  constructor(scope: Construct, id: string, props<%_ if (auth !== 'Cognito') { _%>?<%_ } _%>: <%- nameClassName %>Props) {
    super(scope, id);

    const rc = RuntimeConfig.ensure(this);

    this.dockerImage = AgentRuntimeArtifact.fromAsset(
      path.dirname(url.fileURLToPath(new URL(import.meta.url))),
      {
        platform: Platform.LINUX_ARM64,
        extraHash: execSync(
          `docker inspect <%- dockerImageTag %> --format '{{.Id}}'`,
          { encoding: 'utf-8' },
        ).trim(),
      },
    );

<%_ if (auth === 'Cognito') { _%>
    const { identity, ...restProps } = props;

<%_ } _%>
    this.agentCoreRuntime = new Runtime(this, '<%- nameClassName %>', {
      runtimeName: Lazy.string({
        produce: () =>
          Names.uniqueResourceName(this.agentCoreRuntime, { maxLength: 40 }),
      }),
      protocolConfiguration: ProtocolType.<%- serverProtocol %>,
      agentRuntimeArtifact: this.dockerImage,
<%_ if (auth === 'Cognito') { _%>
      authorizerConfiguration: RuntimeAuthorizerConfiguration.usingCognito(
        identity.userPool,
        [identity.userPoolClient],
      ),
      ...restProps,
<%_ } else { _%>
      ...props,
<%_ } _%>
      environmentVariables: {
        RUNTIME_CONFIG_APP_ID: rc.appConfigApplicationId,
<%_ if (auth === 'Cognito') { _%>
        ...restProps?.environmentVariables,
<%_ } else { _%>
        ...props?.environmentVariables,
<%_ } _%>
      },
    });

    rc.grantReadAppConfig(this.agentCoreRuntime);

    // Register the runtime ARN under the 'agentcore' namespace so that
    // server-side consumers (other agents, MCP clients) can discover it via
    // AppConfig without exposing the ARN in the website's runtime-config.json.
    // To make this agent's ARN available to a frontend, run the
    // `react -> *#strands-agent` connection generator, which patches this file
    // to additionally register the ARN under the 'connection' namespace that
    // gets published to the static website's runtime-config.json.
    rc.set('agentcore', 'agentRuntimes', {
      ...rc.get('agentcore').agentRuntimes,
      <%- nameClassName %>: this.agentCoreRuntime.agentRuntimeArn,
    });
  }

  /**
   * The principal to grant permissions to.
   */
  public get grantPrincipal(): IPrincipal {
    return this.agentCoreRuntime.grantPrincipal;
  }
<%_ if (auth === 'IAM') { _%>

  /**
   * Grants IAM permissions to invoke this agent runtime.
   *
   * @param grantee - The IAM principal to grant permissions to
   */
  public grantInvokeAccess(grantee: IGrantable) {
    this.agentCoreRuntime.grantInvoke(grantee);

    Grant.addToPrincipal({
      grantee,
      actions: [
        'bedrock-agentcore:InvokeAgentRuntimeWithWebSocketStream',
<%_ if (serverProtocol === 'A2A') { _%>
        'bedrock-agentcore:GetAgentCard',
<%_ } _%>
      ],
      resourceArns: [
        this.agentCoreRuntime.agentRuntimeArn,
        `${this.agentCoreRuntime.agentRuntimeArn}/*`,
      ],
    });
  }
<%_ } _%>
}
