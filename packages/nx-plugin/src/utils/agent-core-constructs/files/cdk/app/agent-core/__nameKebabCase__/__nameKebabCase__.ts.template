import { Lazy, Names } from 'aws-cdk-lib';
<%_ if (serverProtocol !== 'MCP') { _%>
import { CfnRuntime } from 'aws-cdk-lib/aws-bedrockagentcore';
<%_ } _%>
import { Platform } from 'aws-cdk-lib/aws-ecr-assets';
import { Connections, IConnectable } from 'aws-cdk-lib/aws-ec2';
import { Construct } from 'constructs';
import * as path from 'path';
import * as url from 'url';
import {
  AgentRuntimeArtifact,
  ProtocolType,
  Runtime,
  RuntimeProps,
<%_ if (auth === 'Cognito') { _%>
  RuntimeAuthorizerConfiguration,
<%_ } _%>
} from '@aws-cdk/aws-bedrock-agentcore-alpha';
import { <%_ if (serverProtocol !== 'MCP') { _%>PolicyStatement, <%_ } _%>IGrantable, IPrincipal<%_ if (auth === 'IAM') { _%>, Grant<%_ } _%> } from 'aws-cdk-lib/aws-iam';
<%_ if (auth === 'Cognito') { _%>
import { IUserPool, IUserPoolClient } from 'aws-cdk-lib/aws-cognito';
<%_ } _%>
import { RuntimeConfig } from '../../../core/runtime-config.js';
import { findWorkspaceRoot } from '../../../core/workspace.js';

<%_ if (serverProtocol !== 'MCP') { _%>
/**
 * Path inside the microVM where AgentCore-managed session storage is
 * mounted. Persists across stop/resume for the same runtimeSessionId, so
 * Strands' SessionManager can restore conversation history after a
 * session is resumed. Must match the `/mnt/<subdir>` pattern required by
 * AgentCore.
 */
const SESSION_STORAGE_MOUNT_PATH = '/mnt/sessions';
<%_ } _%>

<%_ if (auth === 'IAM') { _%>
export type <%- nameClassName %>Props = Omit<
  RuntimeProps,
  | 'runtimeName'
  | 'protocolConfiguration'
  | 'agentRuntimeArtifact'
  | 'authorizerConfiguration'
>;
<%_ } else if (auth === 'Cognito') { _%>
export type <%- nameClassName %>Props = Omit<
  RuntimeProps,
  | 'runtimeName'
  | 'protocolConfiguration'
  | 'agentRuntimeArtifact'
  | 'authorizerConfiguration'
> & {
  /**
   * Identity details for Cognito Authentication
   */
  identity: {
    userPool: IUserPool;
    userPoolClient: IUserPoolClient;
  };
};
<%_ } _%>

export class <%- nameClassName %> extends Construct implements IGrantable, IConnectable {
  public readonly dockerImage: AgentRuntimeArtifact;
  public readonly agentCoreRuntime: Runtime;

  constructor(scope: Construct, id: string, props<%_ if (auth !== 'Cognito') { _%>?<%_ } _%>: <%- nameClassName %>Props) {
    super(scope, id);

    const rc = RuntimeConfig.ensure(this);

    // Resolve the bundle output directory containing the Dockerfile and built artifacts
    const bundleDir = path.join(
      findWorkspaceRoot(url.fileURLToPath(new URL(import.meta.url))),
      '<%- dockerOutputDir %>',
    );

    this.dockerImage = AgentRuntimeArtifact.fromAsset(bundleDir, {
      platform: Platform.LINUX_ARM64,
    });

<%_ if (auth === 'Cognito') { _%>
    const { identity, ...restProps } = props;

<%_ } _%>
    this.agentCoreRuntime = new Runtime(this, '<%- nameClassName %>', {
      runtimeName: Lazy.string({
        produce: () =>
          Names.uniqueResourceName(this.agentCoreRuntime, { maxLength: 40 }),
      }),
      protocolConfiguration: ProtocolType.<%- serverProtocol %>,
      agentRuntimeArtifact: this.dockerImage,
<%_ if (auth === 'Cognito') { _%>
      authorizerConfiguration: RuntimeAuthorizerConfiguration.usingCognito(
        identity.userPool,
        [identity.userPoolClient],
      ),
      ...restProps,
<%_ } else { _%>
      ...props,
<%_ } _%>
      environmentVariables: {
        RUNTIME_CONFIG_APP_ID: rc.appConfigApplicationId,
<%_ if (serverProtocol !== 'MCP') { _%>
        SESSION_STORAGE_PATH: SESSION_STORAGE_MOUNT_PATH,
<%_ } _%>
<%_ if (auth === 'Cognito') { _%>
        ...restProps?.environmentVariables,
<%_ } else { _%>
        ...props?.environmentVariables,
<%_ } _%>
      },
    });

<%_ if (serverProtocol !== 'MCP') { _%>
    // Attach AgentCore-managed session storage so the Strands SessionManager
    // inside the agent can persist conversation history to a mount that
    // survives stop/resume of the same runtimeSessionId.
    //
    // The alpha Runtime construct does not yet expose filesystemConfigurations,
    // so we set the property directly on the underlying CfnRuntime.
    // https://docs.aws.amazon.com/bedrock-agentcore/latest/devguide/runtime-filesystem-configurations.html
    const cfnRuntime = this.agentCoreRuntime.node.defaultChild as CfnRuntime;
    cfnRuntime.filesystemConfigurations = [
      {
        sessionStorage: { mountPath: SESSION_STORAGE_MOUNT_PATH },
      },
    ];

    // Grant access for the agent to invoke bedrock models
    this.agentCoreRuntime.addToRolePolicy(
      new PolicyStatement({
        actions: [
          'bedrock:InvokeModel',
          'bedrock:InvokeModelWithResponseStream',
        ],
        resources: [
          'arn:aws:bedrock:*:*:foundation-model/*',
          'arn:aws:bedrock:*:*:inference-profile/*',
        ],
      }),
    );

<%_ } _%>
    rc.grantReadAppConfig(this.agentCoreRuntime);

    rc.set('agentcore', 'agentRuntimes', {
      ...rc.get('agentcore').agentRuntimes,
      <%- nameClassName %>: this.agentCoreRuntime.agentRuntimeArn,
    });
  }

  /**
   * The principal to grant permissions to.
   */
  public get grantPrincipal(): IPrincipal {
    return this.agentCoreRuntime.grantPrincipal;
  }

  /**
   * Network connections for this agent runtime.
   */
  public get connections(): Connections {
    return this.agentCoreRuntime.connections;
  }
<%_ if (auth === 'IAM') { _%>

  /**
   * Grants IAM permissions to invoke this agent runtime.
   *
   * @param grantee - The IAM principal to grant permissions to
   */
  public grantInvokeAccess(grantee: IGrantable) {
    this.agentCoreRuntime.grantInvoke(grantee);

    Grant.addToPrincipal({
      grantee,
      actions: [
        'bedrock-agentcore:InvokeAgentRuntimeWithWebSocketStream',
<%_ if (serverProtocol === 'A2A') { _%>
        'bedrock-agentcore:GetAgentCard',
<%_ } _%>
      ],
      resourceArns: [
        this.agentCoreRuntime.agentRuntimeArn,
        `${this.agentCoreRuntime.agentRuntimeArn}/*`,
      ],
    });
  }
<%_ } _%>
}
