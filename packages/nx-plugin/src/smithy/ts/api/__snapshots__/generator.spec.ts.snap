exports[`tsSmithyApiGenerator > should generate smithy ts api with default options > backend-project.json 1`] = `
"{
  "name": "@proj/test-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "test-api/backend/src",
  "projectType": "library",
  "tags": [],
  "metadata": {
    "generator": "ts#smithy-api",
    "apiName": "test-api",
    "auth": "custom",
    "modelProject": "@proj/test-api-model",
    "ports": [3001]
  },
  "targets": {
    "build": {
      "dependsOn": ["lint", "compile", "test", "bundle"]
    },
    "compile": {
      "executor": "nx:run-commands",
      "dependsOn": ["copy-ssdk"],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/tsc"],
      "options": {
        "command": "tsc --build tsconfig.lib.json",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["biome"],
      "options": {
        "command": "biome lint {projectRoot}"
      },
      "configurations": {
        "fix": {
          "command": "biome check --write {projectRoot}"
        },
        "skip-lint": {
          "command": "node -e \\"\\""
        }
      }
    },
    "bundle": {
      "executor": "nx:run-commands",
      "dependsOn": ["compile"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/bundle"],
      "options": {
        "command": "rolldown -c rolldown.config.ts",
        "cwd": "{projectRoot}"
      }
    },
    "copy-ssdk": {
      "cache": true,
      "inputs": [
        {
          "dependentTasksOutputFiles": "**/*"
        }
      ],
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "rimraf {projectRoot}/src/generated",
          "make-dir {projectRoot}/src/generated",
          "ncp dist/test-api/model/build/ssdk {projectRoot}/src/generated/ssdk"
        ],
        "parallel": false
      },
      "outputs": ["{projectRoot}/src/generated"],
      "dependsOn": ["@proj/test-api-model:build"]
    },
    "watch-copy-ssdk": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "nx watch --projects=@proj/test-api-model --includeDependencies -- nx run @proj/test-api:copy-ssdk"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "dependsOn": ["copy-ssdk", "watch-copy-ssdk"],
      "continuous": true,
      "options": {
        "command": "tsx --watch src/local-server.ts",
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["copy-ssdk", "watch-copy-ssdk"],
      "continuous": true,
      "options": {
        "command": "tsx --watch src/local-server.ts",
        "cwd": "{projectRoot}",
        "env": {
          "LOCAL_DEV": "true"
        }
      }
    }
  }
}
"
`;

