{
  "name": "@aws/nx-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/nx-plugin/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "compile": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/nx-plugin"],
      "cache": true,
      "dependsOn": ["^compile"],
      "options": {
        "cwd": "{projectRoot}",
        "parallel": false,
        "commands": [
          "node ../../node_modules/@swc/cli/bin/swc.js src sdk bin -d ../../dist/packages/nx-plugin --config-file=.swcrc --copy-files",
          "node ../../node_modules/@swc/cli/bin/swc.js src sdk bin -d ../../dist/packages/nx-plugin/cjs --config-file=.swcrc.cjs",
          "tsc -p tsconfig.lib.json --declaration --emitDeclarationOnly --rootDir . --outDir ../../dist/packages/nx-plugin",
          "node scripts/finalize-package.mjs"
        ]
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/biome.json"],
      "options": {
        "command": "biome lint {projectRoot}/src"
      },
      "configurations": {
        "fix": {
          "command": "biome check --write {projectRoot}/src"
        },
        "skip-lint": {
          "command": "true"
        }
      }
    },
    "generate-3p-license": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm-licenses generate-disclaimer --prod -o LICENSE-THIRD-PARTY",
        "cwd": "{projectRoot}"
      }
    },
    "post-compile": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["chmod +x dist/packages/nx-plugin/bin/aws-nx-mcp.js"]
      },
      "dependsOn": ["compile"]
    },
    "package": {
      "dependsOn": ["compile", "post-compile", "generate-3p-license"]
    },
    "build": {
      "dependsOn": [
        "compile",
        "post-compile",
        "lint",
        "test",
        "generate-3p-license"
      ]
    },
    "mcp-inspect": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["mcp-inspector -- tsx --watch bin/aws-nx-mcp.ts"],
        "cwd": "{projectRoot}"
      }
    }
  }
}
