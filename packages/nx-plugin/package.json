{
  "name": "@aws/nx-plugin",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/awslabs/nx-plugin-for-aws.git",
    "directory": "packages/nx-plugin"
  },
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "typings": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./sdk/*": {
      "types": "./src/sdk/*.d.ts",
      "default": "./src/sdk/*.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "aws-nx-mcp": "./src/bin/aws-nx-mcp.js"
  },
  "generators": "./generators.json",
  "executors": "./executors.json",
  "engines": {
    "node": ">=20.19.0"
  },
  "peerDependencies": {
    "nx": "23.0.1"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "12.1.0",
    "@biomejs/js-api": "6.0.0",
    "@biomejs/wasm-nodejs": "2.5.3",
    "@getgrit/gritql": "0.0.3",
    "@iarna/toml": "2.2.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@nx/devkit": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/react": "23.0.1",
    "@nx/vite": "23.0.1",
    "@types/estree": "1.0.9",
    "@types/js-yaml": "4.0.9",
    "@types/mdast": "4.0.4",
    "@nxlv/python": "22.2.1",
    "@phenomnomnominal/tsquery": "6.2.0",
    "enquirer": "2.4.1",
    "fast-glob": "3.3.3",
    "jiti": "2.7.0",
    "js-yaml": "4.3.0",
    "license-checker-rseidelsohn": "4.4.2",
    "lodash.camelcase": "4.3.0",
    "lodash.clonedeepwith": "4.5.0",
    "lodash.deburr": "4.1.0",
    "lodash.orderby": "4.18.0",
    "lodash.trim": "4.18.0",
    "lodash.uniqby": "4.7.0",
    "mdast-util-mdx-jsx": "3.2.0",
    "minimatch": "10.2.5",
    "openapi-types": "12.1.3",
    "pip-requirements-js": "1.0.3",
    "remark-frontmatter": "5.0.0",
    "remark-mdx": "3.1.1",
    "remark-parse": "11.0.0",
    "remark-stringify": "11.0.0",
    "spdx-satisfies": "6.0.0",
    "typescript": "6.0.3",
