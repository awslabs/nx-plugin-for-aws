import Default from 'starlight-videos/overrides/PageTitle.astro';
import { PAGE_TITLE_ID } from '@astrojs/starlight/constants';
---

<div class="page-title-wrapper">
  <Default><slot /></Default>
  <button
    class="copy-markdown-btn"
    type="button"
    aria-label="Copy page as Markdown"
    title="Copy page as Markdown"
  >
    <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
    <span class="copy-label">Copy as Markdown</span>
  </button>
</div>

<script>
  function initCopyButtons() {
    document.querySelectorAll('.copy-markdown-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const dataEl = document.querySelector('[data-copy-markdown]');
        const markdown = dataEl?.getAttribute('data-copy-markdown');
        if (!markdown) return;

        try {
          await navigator.clipboard.writeText(markdown);
        } catch {
          const textarea = document.createElement('textarea');
          textarea.value = markdown;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
        }

        const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
        const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
        const label = btn.querySelector('.copy-label') as HTMLElement;

        if (copyIcon && checkIcon && label) {
          copyIcon.style.display = 'none';
          checkIcon.style.display = '';
          label.textContent = 'Copied!';

          setTimeout(() => {
            copyIcon.style.display = '';
            checkIcon.style.display = 'none';
            label.textContent = 'Copy as Markdown';
          }, 2000);
        }
      });
    });
  }

  initCopyButtons();
  document.addEventListener('astro:after-swap', initCopyButtons);
</script>

<style>
  .page-title-wrapper {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .copy-markdown-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    margin-top: 1.25rem;
    font-size: 0.8125rem;
    line-height: 1;
    white-space: nowrap;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease;
    flex-shrink: 0;
  }

  .copy-markdown-btn:hover {
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-3);
  }

  .copy-markdown-btn:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .copy-markdown-btn svg {
    flex-shrink: 0;
  }
</style>
