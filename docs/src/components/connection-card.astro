import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ReactMark from './react-mark.astro';

import trpcLogo from '@assets/logos/trpc.svg';
import fastapiLogo from '@assets/logos/fastapi.svg';
import smithyLogo from '@assets/logos/smithy.svg';
import pythonLogo from '@assets/logos/python.svg';
import typescriptLogo from '@assets/logos/typescript.svg';
import strandsLogo from '@assets/logos/strands.svg';
import mcpLogo from '@assets/logos/mcp.svg';
import a2aLogo from '@assets/logos/a2a.svg';
import copilotkitLogo from '@assets/logos/copilotkit.png';

type LogoId =
  | 'react'
  | 'trpc'
  | 'fastapi'
  | 'smithy'
  | 'python'
  | 'typescript'
  | 'strands'
  | 'mcp'
  | 'a2a'
  | 'copilotkit';

interface LogoInfo {
  src?: ImageMetadata;
  alt: string;
}

const logos: Record<LogoId, LogoInfo> = {
  react: { alt: 'React' },
  trpc: { src: trpcLogo, alt: 'tRPC' },
  fastapi: { src: fastapiLogo, alt: 'FastAPI' },
  smithy: { src: smithyLogo, alt: 'Smithy' },
  python: { src: pythonLogo, alt: 'Python' },
  typescript: { src: typescriptLogo, alt: 'TypeScript' },
  strands: { src: strandsLogo, alt: 'Strands Agents' },
  mcp: { src: mcpLogo, alt: 'Model Context Protocol' },
  a2a: { src: a2aLogo, alt: 'Agent2Agent' },
  copilotkit: { src: copilotkitLogo, alt: 'CopilotKit' },
};

interface Props {
  title: string;
  description: string;
  href: string;
  source: LogoId;
  target: LogoId;
  sourceBadge?: LogoId;
  targetBadge?: LogoId;
}

const { title, description, href, source, target, sourceBadge, targetBadge } =
  Astro.props;

const src = logos[source];
const tgt = logos[target];
const srcBadge = sourceBadge ? logos[sourceBadge] : undefined;
const tgtBadge = targetBadge ? logos[targetBadge] : undefined;
---

<div class="connection-card">
  <a href={href} class="cover-link" aria-label={title}></a>
  <div class="logos">
    <span class={`logo-tile logo-${source}`}>
      {
        source === 'react' ? (
          <ReactMark />
        ) : (
          <Image src={src.src!} alt={src.alt} loading="lazy" />
        )
      }
      {
        srcBadge && (
          <span class={`badge badge-${sourceBadge}`}>
            <Image src={srcBadge.src!} alt={srcBadge.alt} loading="lazy" />
          </span>
        )
      }
    </span>
    <svg
      class="arrow"
      viewBox="0 0 24 24"
      aria-hidden="true"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
    <span class={`logo-tile logo-${target}`}>
      {
        target === 'react' ? (
          <ReactMark />
        ) : (
          <Image src={tgt.src!} alt={tgt.alt} loading="lazy" />
        )
      }
      {
        tgtBadge && (
          <span class={`badge badge-${targetBadge}`}>
            <Image src={tgtBadge.src!} alt={tgtBadge.alt} loading="lazy" />
          </span>
        )
      }
    </span>
  </div>
  <span class="title">{title}</span>
  <span class="description">{description}</span>
</div>

<style>
  .connection-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 1rem;
    box-shadow: var(--sl-shadow-sm);
  }

  .connection-card:hover {
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border-color: var(--sl-color-gray-2);
  }

  .cover-link {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 1;
  }

  .logos {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .logo-tile {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    padding: 0.4rem;
    background: transparent;
    flex-shrink: 0;
  }

  .logo-tile :global(img) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  /* A2A mark is pure black — invert it for visibility in dark mode */
  :global([data-theme='dark']) .logo-tile.logo-a2a :global(img) {
    filter: invert(1);
  }

  .badge {
    position: absolute;
    right: -6px;
    bottom: -6px;
    width: 1.25rem;
    height: 1.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    background: transparent;
  }

  .badge :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .arrow {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--sl-color-gray-3);
    flex-shrink: 0;
  }

  .connection-card:hover .arrow {
    color: var(--sl-color-white);
  }

  .title {
    color: var(--sl-color-white);
    font-weight: 600;
    font-size: var(--sl-text-lg);
    line-height: var(--sl-line-height-headings);
  }

  .description {
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }

  .cover-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }
</style>
