---
import PackageManagerCommand from './package-manager-command.astro';
import { buildPackageManagerShortCommand } from '../../../packages/nx-plugin/src/utils/commands';

const { commands, highlights = [] } = Astro.props;

const buildCommand = (pm) => commands.map(c => buildPackageManagerShortCommand(pm, c)).join('\n');
---
<PackageManagerCommand highlights={highlights} buildCommand={buildCommand} />
