import Default from '@astrojs/starlight/components/MarkdownContent.astro';

const isSnippet = Astro.locals.starlightRoute?.id?.includes('/snippets/');
---

<div class="sl-markdown-content-wrapper">
  {!isSnippet && (
    <button
      class="copy-markdown-btn"
      type="button"
      aria-label="Copy page as Markdown"
      title="Copy page as Markdown"
    >
      <svg class="copy-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg class="check-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      <span class="copy-label">Copy as Markdown</span>
    </button>
  )}
  <Default><slot /></Default>
</div>

<script>
  import TurndownService from 'turndown';

  function createTurndownService(): TurndownService {
    const td = new TurndownService({
      headingStyle: 'atx',
      codeBlockStyle: 'fenced',
      bulletListMarker: '-',
    });

    // Handle Shiki/Expressive Code blocks
    td.addRule('codeBlock', {
      filter(node) {
        if (node.nodeName === 'DIV' && node.classList.contains('expressive-code')) {
          return true;
        }
        // Also match <figure> with expressive-code class (newer versions)
        if (node.nodeName === 'FIGURE' && node.classList.contains('expressive-code')) {
          return true;
        }
        return false;
      },
      replacement(_content, node) {
        const el = node as HTMLElement;
        const codeEl = el.querySelector('code');
        if (!codeEl) return '';
        const lang = codeEl.dataset.language || '';
        // Get text content, preserving line structure
        const text = codeEl.textContent?.replace(/\n$/, '') || '';
        return `\n\n\`\`\`${lang}\n${text}\n\`\`\`\n\n`;
      },
    });

    // Handle Starlight aside/admonition blocks
    td.addRule('aside', {
      filter(node) {
        return node.nodeName === 'ASIDE' && node.classList.contains('starlight-aside');
      },
      replacement(_content, node) {
        const el = node as HTMLElement;
        const titleEl = el.querySelector('.starlight-aside__title');
        const contentEl = el.querySelector('.starlight-aside__content');
        const title = titleEl?.textContent?.trim() || 'Note';
        const content = contentEl
          ? td.turndown(contentEl.innerHTML)
          : '';
        const quotedContent = content
          .split('\n')
          .map((line: string) => `> ${line}`)
          .join('\n');
        return `\n\n> **${title}**\n>\n${quotedContent}\n\n`;
      },
    });

    // Handle Starlight tabs
    td.addRule('tabGroup', {
      filter(node) {
        return node.nodeName === 'STARLIGHT-TABS';
      },
      replacement(_content, node) {
        const el = node as HTMLElement;
        const panels = el.querySelectorAll('[role="tabpanel"]');
        const tabs = el.querySelectorAll('[role="tab"]');
        const parts: string[] = [];

        panels.forEach((panel, i) => {
          const tabLabel = tabs[i]?.textContent?.trim() || `Tab ${i + 1}`;
          const panelContent = td.turndown((panel as HTMLElement).innerHTML);
          parts.push(`**${tabLabel}**\n\n${panelContent}`);
        });

        return `\n\n${parts.join('\n\n---\n\n')}\n\n`;
      },
    });

    // Handle file tree
    td.addRule('fileTree', {
      filter(node) {
        return node.nodeName === 'UL' && node.classList.contains('sl-tree');
      },
      replacement(_content, node) {
        const el = node as HTMLElement;
        function walk(ul: HTMLElement, indent: number): string {
          const items = ul.querySelectorAll(':scope > li');
          return Array.from(items).map((li) => {
            const nameEl = li.querySelector(':scope > span.sl-tree-file, :scope > details > summary > span');
            const name = nameEl?.textContent?.trim() || li.textContent?.trim()?.split('\n')[0] || '';
            const prefix = '  '.repeat(indent) + '- ';
            const nestedUl = li.querySelector(':scope > ul, :scope > details > ul');
            const children = nestedUl ? '\n' + walk(nestedUl as HTMLElement, indent + 1) : '';
            return prefix + name + children;
          }).join('\n');
        }
        return `\n\n${walk(el, 0)}\n\n`;
      },
    });

    // Skip copy buttons and other interactive chrome
    td.addRule('skipInteractive', {
      filter(node) {
        if (node.nodeName === 'BUTTON') return true;
        if ((node as HTMLElement).classList?.contains('copy')) return true;
        return false;
      },
      replacement() {
        return '';
      },
    });

    // Remove the copy-markdown button itself from output
    td.addRule('skipCopyMarkdownBtn', {
      filter(node) {
        return (node as HTMLElement).classList?.contains('copy-markdown-btn') === true;
      },
      replacement() {
        return '';
      },
    });

    return td;
  }

  function initCopyButtons() {
    document.querySelectorAll('.copy-markdown-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const wrapper = btn.closest('.sl-markdown-content-wrapper');
        const content = wrapper?.querySelector('.sl-markdown-content');
        if (!content) return;

        const td = createTurndownService();

        // Get the page title
        const pageTitle = document.querySelector('h1')?.textContent?.trim() || '';
        const markdown = (pageTitle ? `# ${pageTitle}\n\n` : '') + td.turndown(content.innerHTML);

        try {
          await navigator.clipboard.writeText(markdown);
          const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
          const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
          const label = btn.querySelector('.copy-label') as HTMLElement;

          if (copyIcon && checkIcon && label) {
            copyIcon.style.display = 'none';
            checkIcon.style.display = '';
            label.textContent = 'Copied!';

            setTimeout(() => {
              copyIcon.style.display = '';
              checkIcon.style.display = 'none';
              label.textContent = 'Copy as Markdown';
            }, 2000);
          }
        } catch {
          // Fallback for older browsers
          const textarea = document.createElement('textarea');
          textarea.value = markdown;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
        }
      });
    });
  }

  // Run on initial load
  initCopyButtons();

  // Re-run after Astro view transitions
  document.addEventListener('astro:after-swap', initCopyButtons);
</script>

<style>
  .sl-markdown-content-wrapper {
    position: relative;
  }

  .copy-markdown-btn {
    position: absolute;
    top: 0;
    right: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    line-height: 1;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    cursor: pointer;
    opacity: 0;
    transition: opacity 150ms ease, color 150ms ease, border-color 150ms ease;
    z-index: 1;
  }

  .sl-markdown-content-wrapper:hover .copy-markdown-btn {
    opacity: 1;
  }

  .copy-markdown-btn:hover {
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-3);
  }

  .copy-markdown-btn:focus-visible {
    opacity: 1;
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .copy-markdown-btn svg {
    flex-shrink: 0;
  }
</style>
