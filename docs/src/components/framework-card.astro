import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import trpcLogo from '@assets/logos/trpc.svg';
import fastapiLogo from '@assets/logos/fastapi.svg';
import smithyLogo from '@assets/logos/smithy.svg';
import reactLogo from '@assets/logos/react.svg';
import astroLogoDark from '@assets/logos/astro-dark.svg';
import astroLogoLight from '@assets/logos/astro-light.svg';

type LogoId = 'trpc' | 'fastapi' | 'smithy' | 'react' | 'astro';

interface LogoInfo {
  src: ImageMetadata;
  darkSrc?: ImageMetadata;
  alt: string;
}

const logos: Record<LogoId, LogoInfo> = {
  trpc: { src: trpcLogo, alt: 'tRPC' },
  fastapi: { src: fastapiLogo, alt: 'FastAPI' },
  smithy: { src: smithyLogo, alt: 'Smithy' },
  react: { src: reactLogo, alt: 'React' },
  astro: { src: astroLogoDark, darkSrc: astroLogoLight, alt: 'Astro' },
};

interface Props {
  title: string;
  description: string;
  href: string;
  logo: LogoId;
}

const { title, description, href, logo } = Astro.props;
const logoInfo = logos[logo];
---

<div class="framework-card">
  <a href={href} class="cover-link" aria-label={title}></a>
  <div class="logo-area">
    <span class={`logo-tile${logoInfo.darkSrc ? ' has-dark-variant' : ''}`}>
      <Image src={logoInfo.src} alt={logoInfo.alt} loading="lazy" class="light-logo" />
      {logoInfo.darkSrc && (
        <Image src={logoInfo.darkSrc} alt={logoInfo.alt} loading="lazy" class="dark-logo" />
      )}
    </span>
  </div>
  <span class="title">{title}</span>
  <span class="description">{description}</span>
</div>

<style>
  .framework-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 1rem;
    box-shadow: var(--sl-shadow-sm);
  }

  .framework-card:hover {
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border-color: var(--sl-color-gray-2);
  }

  .cover-link {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 1;
  }

  .cover-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .logo-area {
    display: flex;
    align-items: center;
    margin-bottom: 0.25rem;
  }

  .logo-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    padding: 0.4rem;
  }

  .logo-tile :global(img) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .logo-tile.has-dark-variant :global(.dark-logo) {
    display: none;
  }

  :global([data-theme='dark']) .logo-tile.has-dark-variant :global(.light-logo) {
    display: none;
  }

  :global([data-theme='dark']) .logo-tile.has-dark-variant :global(.dark-logo) {
    display: block;
  }

  .title {
    color: var(--sl-color-white);
    font-weight: 600;
    font-size: var(--sl-text-lg);
    line-height: var(--sl-line-height-headings);
  }

  .description {
    color: var(--sl-color-gray-3);
    line-height: 1.5;
  }
</style>
