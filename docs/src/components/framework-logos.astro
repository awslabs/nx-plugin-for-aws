import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import reactLogo from '@assets/logos/react.svg';
import viteLogo from '@assets/logos/vite.svg';
import trpcLogo from '@assets/logos/trpc.svg';
import fastapiLogo from '@assets/logos/fastapi.svg';
import smithyLogo from '@assets/logos/smithy.svg';
import strandsLogo from '@assets/logos/strands.svg';
import mcpLogo from '@assets/logos/mcp.svg';
import cdkLogo from '@assets/logos/cdk.svg';
import cdkLogoDark from '@assets/logos/cdk-white.svg';
import terraformLogo from '@assets/logos/terraform.svg';
import shadcnLogo from '@assets/logos/shadcn.svg';
import shadcnLogoDark from '@assets/logos/shadcn-white.svg';

interface Framework {
  src: ImageMetadata;
  darkSrc?: ImageMetadata;
  name: string;
  href: string;
}

const frameworks: Framework[] = [
  { name: 'React', src: reactLogo, href: 'https://react.dev/' },
  { name: 'Vite', src: viteLogo, href: 'https://vite.dev/' },
  { name: 'shadcn/ui', src: shadcnLogo, darkSrc: shadcnLogoDark, href: 'https://ui.shadcn.com/' },
  { name: 'tRPC', src: trpcLogo, href: 'https://trpc.io/' },
  { name: 'FastAPI', src: fastapiLogo, href: 'https://fastapi.tiangolo.com/' },
  { name: 'Smithy', src: smithyLogo, href: 'https://smithy.io/' },
  { name: 'Strands Agents', src: strandsLogo, href: 'https://strandsagents.com/' },
  { name: 'MCP', src: mcpLogo, href: 'https://modelcontextprotocol.io/' },
  { name: 'AWS CDK', src: cdkLogo, darkSrc: cdkLogoDark, href: 'https://docs.aws.amazon.com/cdk/' },
  { name: 'Terraform', src: terraformLogo, href: 'https://developer.hashicorp.com/terraform' },
];
---

<div class="framework-logos">
  {
    frameworks.map((framework) => (
      <a
        class="framework-logo"
        href={framework.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={framework.name}
      >
        <span class={`logo-tile${framework.darkSrc ? ' has-dark-variant' : ''}`}>
          <Image src={framework.src} alt={framework.name} loading="lazy" class="light-logo" />
          {framework.darkSrc && (
            <Image src={framework.darkSrc} alt={framework.name} loading="lazy" class="dark-logo" />
          )}
        </span>
        <span class="name">{framework.name}</span>
      </a>
    ))
  }
</div>

<style>
  .framework-logos {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(8rem, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .framework-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 1.25rem 0.75rem;
    box-shadow: var(--sl-shadow-sm);
    transition: background 0.15s ease, border-color 0.15s ease;
  }

  .framework-logo:hover {
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border-color: var(--sl-color-gray-2);
  }

  .logo-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
  }

  .logo-tile :global(img) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .logo-tile.has-dark-variant :global(.dark-logo) {
    display: none;
  }

  :global([data-theme='dark']) .logo-tile.has-dark-variant :global(.light-logo) {
    display: none;
  }

  :global([data-theme='dark']) .logo-tile.has-dark-variant :global(.dark-logo) {
    display: block;
  }

  .name {
    font-size: var(--sl-text-sm);
    font-weight: 600;
    text-align: center;
  }
</style>
